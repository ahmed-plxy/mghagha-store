<%- include('../partials/header', { title: 'بيع حاجة' }) %>

<div class="container" style="max-width:680px;padding-bottom:60px;">
  <div class="page-header-row" style="margin-top:20px;">
    <div>
      <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 4px;">🏷️ بيع حاجة مستعملة</h1>
      <p style="color:var(--color-muted);margin:0;font-size:.92rem;">النشر مجاني ومتاح لكل أهل مغاغة، وإعلانك يظهر للجميع فورًا بعد النشر</p>
    </div>
  </div>

  <% if (errors && errors.length > 0) { %>
  <div class="pf-errors">
    <% errors.forEach(function(e) { %><p>⚠️ <%= e %></p><% }) %>
  </div>
  <% } %>

  <form action="/customer/sell" method="POST" enctype="multipart/form-data" class="pf-form" id="sellForm">

    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">١</span>
        إيه اللي بتبيعه؟
      </div>

      <div class="pf-form" style="gap:12px;">
        <div>
          <label class="pf-label" for="nameInput">اسم الحاجة <span style="color:var(--color-danger)">*</span></label>
          <input type="text" name="name" id="nameInput" class="pf-input" placeholder="مثلاً: موبايل سامسونج A54 مستعمل" required value="<%= values.name || '' %>">
        </div>
        <div>
          <label class="pf-label" for="priceInput">السعر (جنيه مصري) <span style="color:var(--color-danger)">*</span></label>
          <input type="number" name="price" id="priceInput" class="pf-input" placeholder="0" min="0" step="1" value="<%= values.price || '' %>">
        </div>
        <div>
          <label class="pf-label" for="descInput">وصف الحاجة</label>
          <textarea name="description" id="descInput" class="pf-input" rows="4" placeholder="اوصف الحالة، العمر، سبب البيع..."><%= values.description || '' %></textarea>
        </div>
      </div>
    </div>

    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٢</span>
        حالة الحاجة
      </div>
      <div class="pf-cat-grid" id="conditionGrid">
        <% var condOptions = [
          { value: 'new', label: 'جديدة', emoji: '✨' },
          { value: 'like_new', label: 'كالجديدة', emoji: '🌟' },
          { value: 'used', label: 'مستعملة', emoji: '👍' },
          { value: 'for_parts', label: 'للقطع غيار', emoji: '🔧' }
        ]; %>
        <% condOptions.forEach(function(opt) { %>
        <label class="pf-cat-chip <%= (values.condition || 'used') === opt.value ? 'active' : '' %>">
          <input type="radio" name="condition" value="<%= opt.value %>" <%= (values.condition || 'used') === opt.value ? 'checked' : '' %> style="display:none;">
          <span class="pf-cat-icon"><%= opt.emoji %></span>
          <span class="pf-cat-label"><%= opt.label %></span>
        </label>
        <% }) %>
      </div>
    </div>

    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٣</span>
        القسم (اختياري)
      </div>
      <div class="pf-cat-grid">
        <% categories.forEach(function(cat) { %>
        <label class="pf-cat-chip <%= values.categoryId == cat.id ? 'active' : '' %>" id="chip-<%= cat.id %>">
          <input type="radio" name="categoryId" value="<%= cat.id %>" <%= values.categoryId == cat.id ? 'checked' : '' %> style="display:none;">
          <span class="pf-cat-icon"><%= cat.emoji %></span>
          <span class="pf-cat-label"><%= cat.name %></span>
        </label>
        <% }) %>
      </div>
    </div>

    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٤</span>
        صور الحاجة
      </div>
      <div class="pf-file-wrap" id="dropZone">
        <label class="pf-file-label" for="imagesInput">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36" style="color:var(--color-muted)"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span style="font-weight:700;margin:8px 0 4px;display:block;">ارفع صور (حتى 6)</span>
          <span style="color:var(--color-muted);font-size:.85rem;">JPEG / PNG / WEBP — حجم أقصى 5 ميجا للصورة</span>
        </label>
        <input type="file" name="images" id="imagesInput" accept="image/jpeg,image/png,image/webp" multiple style="display:none;">
      </div>
      <div class="image-thumbs" id="imgPreviewWrap" style="margin-top:12px;"></div>
    </div>

    <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;font-size:1.05rem;font-weight:800;" id="submitBtn">
      نشر الإعلان
    </button>
  </form>
</div>

<style>
.pf-label { display:block;font-size:.88rem;font-weight:600;color:var(--color-text);margin-bottom:6px; }
</style>

<script>
(function() {
  document.querySelectorAll('.pf-cat-grid').forEach(function(grid) {
    grid.querySelectorAll('.pf-cat-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        grid.querySelectorAll('.pf-cat-chip').forEach(function(c) { c.classList.remove('active'); });
        chip.classList.add('active');
      });
    });
  });

  var input = document.getElementById('imagesInput');
  var wrap = document.getElementById('imgPreviewWrap');
  var dropZone = document.getElementById('dropZone');

  dropZone.addEventListener('click', function() { input.click(); });
  dropZone.addEventListener('dragover', function(e) { e.preventDefault(); dropZone.style.borderColor='var(--color-primary)'; });
  dropZone.addEventListener('dragleave', function() { dropZone.style.borderColor=''; });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropZone.style.borderColor='';
    input.files = e.dataTransfer.files;
    showPreviews(input.files);
  });

  input.addEventListener('change', function() { showPreviews(this.files); });

  function showPreviews(files) {
    wrap.innerHTML = '';
    Array.from(files).slice(0, 6).forEach(function(file) {
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = document.createElement('img');
        img.src = e.target.result;
        img.className = 'thumb';
        wrap.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  }

  document.getElementById('sellForm').addEventListener('submit', function() {
    document.getElementById('submitBtn').disabled = true;
    document.getElementById('submitBtn').textContent = 'جاري النشر...';
  });
})();
</script>

<%- include('../partials/footer') %>
