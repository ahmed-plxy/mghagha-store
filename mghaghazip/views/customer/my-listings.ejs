<%- include('../partials/header', { title: 'إعلاناتي' }) %>

<div class="container" style="padding-bottom:60px;">
  <div class="page-header-row" style="margin-top:20px;">
    <h1 style="font-size:1.4rem;font-weight:800;margin:0;">إعلاناتي</h1>
    <a href="/customer/sell" class="btn btn-primary" style="font-size:.9rem;">+ إعلان جديد</a>
  </div>

  <% if (listings.length === 0) { %>
  <div style="text-align:center;padding:60px 20px;color:var(--color-muted);">
    <div style="font-size:3rem;margin-bottom:16px;">🏷️</div>
    <p style="font-size:1.1rem;font-weight:700;">ماعندكش إعلانات لسه</p>
    <p style="margin-bottom:20px;">انشر أول إعلان واوصل للناس في مغاغة</p>
    <a href="/customer/sell" class="btn btn-primary">بيع حاجة دلوقتي</a>
  </div>
  <% } else { %>
  <div class="grid" style="margin-top:20px;">
    <% listings.forEach(function(listing) { %>
    <div class="card-link" style="display:block;position:relative;">
      <% if (listing.status === 'sold') { %>
        <div style="position:absolute;top:10px;right:10px;z-index:2;background:var(--color-muted);color:#fff;font-size:.75rem;font-weight:700;padding:3px 10px;border-radius:20px;">متباع</div>
      <% } %>
      <% if (listing.images && listing.images.length > 0) { %>
        <img src="/uploads/<%= listing.images[0].image_url %>" class="card-image" alt="<%= listing.name %>">
      <% } else { %>
        <div class="card-image-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
      <% } %>
      <div class="card-body">
        <p class="card-title"><%= listing.name %></p>
        <p class="card-price"><%= listing.price.toFixed(0) %> جنيه</p>
        <p class="card-meta" style="margin-top:6px;"><%= listing.category_name || 'غير محدد' %></p>
        <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">
          <a href="/classifieds/<%= listing.slug %>" class="btn btn-secondary btn-small">عرض</a>
          <% if (listing.status === 'active') { %>
          <form action="/customer/my-listings/<%= listing.id %>/sold" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-small" style="background:var(--color-bg-alt);color:var(--color-text);" onclick="return confirm('تعليم كمتباع؟')">تعليم متباع</button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
