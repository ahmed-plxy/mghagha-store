<%- include('../partials/header', { title: 'أكمل بياناتك' }) %>

<div class="auth-page">
  <div class="cp-card">

    <div class="cp-header">
      <% if (user && user.avatar_url) { %>
        <img src="<%= user.avatar_url %>" alt="صورتك" class="cp-avatar">
      <% } else { %>
        <div class="cp-avatar-placeholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
      <% } %>
      <h1 class="cp-title">
        <% if (user && user.full_name) { %>أهلاً، <%= user.full_name.split(' ')[0] %>!
        <% } else { %>خطوة أخيرة<% } %>
      </h1>
      <p class="cp-subtitle">نحتاج بعض المعلومات عشان تكمل حسابك</p>
    </div>

    <div class="cp-progress">
      <div class="cp-step cp-step--done">
        <span class="cp-step-dot">✓</span>
        <span class="cp-step-label">إنشاء الحساب</span>
      </div>
      <div class="cp-step-line"></div>
      <div class="cp-step cp-step--done">
        <span class="cp-step-dot">✓</span>
        <span class="cp-step-label">التحقق</span>
      </div>
      <div class="cp-step-line"></div>
      <div class="cp-step cp-step--active">
        <span class="cp-step-dot">3</span>
        <span class="cp-step-label">بياناتك</span>
      </div>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="cp-alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div><% errors.forEach(function(e){ %><p><%= e %></p><% }) %></div>
      </div>
    <% } %>

    <form action="/auth/complete-profile" method="POST" class="cp-form">

      <div class="cp-field">
        <label class="cp-label" for="areaId">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          منطقتك أو قريتك <span class="cp-required">*</span>
        </label>
        <select id="areaId" name="areaId" required class="cp-input">
          <option value="">— اختار المنطقة الأقرب ليك —</option>
          <% if (areas && areas.length > 0) { %>
            <% areas.forEach(function(area) { %>
              <option value="<%= area.id %>" <%= (old.areaId && old.areaId == area.id) ? 'selected' : '' %>>
                <%= area.name %>
              </option>
            <% }) %>
          <% } %>
        </select>
        <span class="cp-hint">مطلوب — بتساعدنا نعرضلك المحلات الأقرب ليك</span>
      </div>

      <div class="cp-field">
        <label class="cp-label" for="phone">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.58 3.45 2 2 0 0 1 3.55 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.27 6.27l1.62-1.62a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          رقم الهاتف <span class="cp-optional">(اختياري)</span>
        </label>
        <input type="tel" id="phone" name="phone"
          value="<%= old.phone || '' %>"
          placeholder="01012345678"
          autocomplete="tel" class="cp-input"
          inputmode="numeric" maxlength="11">
        <span class="cp-hint">رقم مصري يبدأ بـ 010 / 011 / 012 / 015</span>
      </div>

      <button type="submit" class="cp-submit">
        متابعة
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

    </form>

    <div class="cp-footer">
      <form action="/auth/logout" method="POST" style="display:inline;">
        <button type="submit" class="cp-logout-btn">تسجيل الخروج</button>
      </form>
    </div>

  </div>
</div>

<style>
.auth-page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px 16px 60px; background:var(--color-bg); }
.cp-card { width:100%; max-width:460px; background:var(--color-card); border-radius:20px; box-shadow:var(--shadow-card); overflow:hidden; }

.cp-header { background:linear-gradient(135deg, var(--color-primary), var(--color-primary-dark)); padding:28px 24px 24px; text-align:center; }
.cp-avatar { width:68px; height:68px; border-radius:50%; border:3px solid rgba(255,255,255,.4); object-fit:cover; margin-bottom:12px; }
.cp-avatar-placeholder { width:68px; height:68px; border-radius:50%; background:rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; margin:0 auto 12px; }
.cp-title { color:#fff; font-size:1.2rem; font-weight:700; margin:0 0 6px; }
.cp-subtitle { color:rgba(255,255,255,.75); font-size:.88rem; margin:0; }

.cp-progress { display:flex; align-items:center; justify-content:center; padding:18px 24px 4px; }
.cp-step { display:flex; flex-direction:column; align-items:center; gap:5px; flex-shrink:0; }
.cp-step-dot { width:28px; height:28px; border-radius:50%; background:var(--color-border); color:var(--color-muted); font-size:.75rem; font-weight:700; display:flex; align-items:center; justify-content:center; }
.cp-step-label { font-size:.72rem; color:var(--color-muted); white-space:nowrap; }
.cp-step--done .cp-step-dot { background:var(--color-primary-tint); color:var(--color-primary); }
.cp-step--active .cp-step-dot { background:var(--color-primary); color:#fff; }
.cp-step--active .cp-step-label { color:var(--color-primary); font-weight:600; }
.cp-step-line { flex:1; height:2px; background:var(--color-border); margin:0 6px; min-width:20px; align-self:flex-start; margin-top:14px; }

.cp-alert { display:flex; align-items:flex-start; gap:10px; background:var(--color-danger-tint); border:1px solid var(--color-danger); border-radius:10px; padding:12px 14px; margin:16px 20px 0; color:var(--color-danger); font-size:.88rem; }
.cp-alert p { margin:0; line-height:1.5; }
.cp-alert svg { flex-shrink:0; margin-top:2px; stroke:var(--color-danger); }

.cp-form { padding:20px 20px; display:flex; flex-direction:column; gap:18px; }
.cp-field { display:flex; flex-direction:column; gap:5px; }
.cp-label { font-size:.85rem; font-weight:600; color:var(--color-text); display:flex; align-items:center; gap:5px; }
.cp-required { color:var(--color-danger); font-size:.9rem; }
.cp-optional { color:var(--color-muted); font-size:.78rem; font-weight:400; }
.cp-input { width:100%; padding:11px 14px; border:1.5px solid var(--color-border); border-radius:10px; font-size:.95rem; background:var(--color-bg); color:var(--color-text); outline:none; transition:border-color .15s, box-shadow .15s; box-sizing:border-box; font-family:inherit; }
.cp-input:focus { border-color:var(--color-primary); box-shadow:0 0 0 3px var(--color-primary-tint); }
.cp-hint { font-size:.78rem; color:var(--color-muted); }

.cp-submit { width:100%; padding:13px 20px; background:var(--color-primary); color:#fff; border:none; border-radius:12px; font-size:1rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:background .15s; font-family:inherit; }
.cp-submit:hover { background:var(--color-primary-dark); }

.cp-footer { padding:10px 20px 18px; text-align:center; }
.cp-logout-btn { background:none; border:none; font-size:.82rem; color:var(--color-muted); cursor:pointer; text-decoration:underline; font-family:inherit; }
.cp-logout-btn:hover { color:var(--color-text); }
</style>

<%- include('../partials/footer') %>
