<%- include('../partials/header', { title: 'افتح حساب بالإيميل' }) %>

<div class="auth-page">
  <div class="re-card">

    <div class="re-header">
      <div class="re-header-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </div>
      <h1 class="re-title">إنشاء حساب جديد</h1>
      <p class="re-subtitle">هنبعتلك كود تفعيل على إيميلك</p>
    </div>

    <% if (locals.googleEnabled) { %>
    <a href="/auth/google" class="re-google-btn">
      <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      الدخول بجوجل أسرع وأسهل
    </a>
    <div class="re-or"><span>أو سجّل بالإيميل</span></div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="re-alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div><% errors.forEach(function(e){ %><p><%= e %></p><% }) %></div>
      </div>
    <% } %>

    <form action="/auth/register-email" method="POST" class="re-form" id="reForm" autocomplete="on" novalidate>

      <div class="re-field">
        <label class="re-label" for="fullName">الاسم الكامل</label>
        <input type="text" id="fullName" name="fullName"
          value="<%= old.fullName || '' %>"
          placeholder="مثال: أحمد محمد السيد"
          required autocomplete="name" class="re-input" dir="rtl">
        <span class="re-hint">اسمك الحقيقي — 3 حروف على الأقل</span>
      </div>

      <div class="re-field">
        <label class="re-label" for="email">الإيميل</label>
        <div class="re-input-row">
          <input type="email" id="email" name="email"
            value="<%= old.email || '' %>"
            placeholder="example@gmail.com"
            required autocomplete="email" class="re-input" dir="ltr"
            oninput="checkEmail(this)">
          <span class="re-email-tick" id="emailTick"></span>
        </div>
        <span class="re-hint">هيتبعتلك عليه كود التفعيل</span>
      </div>

      <div class="re-two">
        <div class="re-field">
          <label class="re-label" for="password">كلمة السر</label>
          <div class="re-input-wrap">
            <input type="password" id="password" name="password"
              required minlength="8" autocomplete="new-password"
              class="re-input" placeholder="••••••••"
              oninput="updateStrength(this.value)">
            <button type="button" class="re-eye" onclick="toggleVis('password',this)" tabindex="-1">
              <svg class="eye-on" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-off" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <div class="re-strength-bar"><div class="re-strength-fill" id="strengthFill"></div></div>
          <span class="re-hint" id="strengthLabel">8 حروف على الأقل</span>
        </div>

        <div class="re-field">
          <label class="re-label" for="confirmPassword">تأكيد كلمة السر</label>
          <div class="re-input-wrap">
            <input type="password" id="confirmPassword" name="confirmPassword"
              required minlength="8" autocomplete="new-password"
              class="re-input" placeholder="••••••••"
              oninput="checkMatch()">
            <button type="button" class="re-eye" onclick="toggleVis('confirmPassword',this)" tabindex="-1">
              <svg class="eye-on" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-off" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <span class="re-hint" id="matchHint">&nbsp;</span>
        </div>
      </div>

      <label class="re-terms">
        <input type="checkbox" name="agreeTerms" id="agreeTerms" value="1" onchange="toggleBtn()">
        <span class="re-terms-text">
          أوافق على <a href="/privacy" target="_blank">سياسة الخصوصية</a>
          و<a href="/terms" target="_blank">شروط الاستخدام</a>
        </span>
      </label>

      <button type="submit" class="re-submit" id="submitBtn" disabled>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        إنشاء الحساب وإرسال كود التفعيل
      </button>
    </form>

    <p class="re-footer-link">عندك حساب؟ <a href="/auth/login">ادخل من هنا</a></p>
  </div>
</div>

<style>
.auth-page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px 16px 60px; background:var(--color-bg); }
.re-card { width:100%; max-width:500px; background:var(--color-card); border-radius:20px; box-shadow:var(--shadow-card); overflow:hidden; }

.re-header { background:linear-gradient(135deg, var(--color-primary), var(--color-primary-dark)); padding:32px 28px 28px; text-align:center; }
.re-header-icon { width:60px; height:60px; background:rgba(255,255,255,.18); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; }
.re-title { color:#fff; font-size:1.35rem; font-weight:700; margin:0 0 6px; }
.re-subtitle { color:rgba(255,255,255,.75); font-size:.9rem; margin:0; }

.re-google-btn { display:flex; align-items:center; justify-content:center; gap:10px; margin:20px 24px 4px; padding:12px 16px; background:var(--color-bg-alt); border:1.5px solid var(--color-border); border-radius:12px; text-decoration:none; color:var(--color-text); font-size:.9rem; font-weight:600; transition:background .15s, border-color .15s; }
.re-google-btn:hover { background:var(--color-bg); border-color:var(--color-primary); }

.re-or { display:flex; align-items:center; gap:10px; margin:14px 24px 0; color:var(--color-muted); font-size:.8rem; }
.re-or::before, .re-or::after { content:''; flex:1; border-top:1px solid var(--color-border); }

.re-alert { display:flex; align-items:flex-start; gap:10px; background:var(--color-danger-tint); border:1px solid var(--color-danger); border-radius:10px; padding:12px 14px; margin:16px 24px 0; color:var(--color-danger); font-size:.88rem; }
.re-alert p { margin:0; line-height:1.5; }
.re-alert svg { flex-shrink:0; margin-top:2px; }

.re-form { padding:20px 24px 24px; display:flex; flex-direction:column; gap:16px; }
.re-field { display:flex; flex-direction:column; gap:5px; }
.re-label { font-size:.85rem; font-weight:600; color:var(--color-text); }
.re-input { width:100%; padding:11px 14px; border:1.5px solid var(--color-border); border-radius:10px; font-size:.95rem; background:var(--color-bg); color:var(--color-text); outline:none; transition:border-color .15s, box-shadow .15s; box-sizing:border-box; font-family:inherit; }
.re-input:focus { border-color:var(--color-primary); box-shadow:0 0 0 3px var(--color-primary-tint); }
.re-hint { font-size:.78rem; color:var(--color-muted); }

.re-input-row { position:relative; display:flex; align-items:center; }
.re-input-row .re-input { padding-left:40px; }
.re-email-tick { position:absolute; left:12px; font-size:1rem; transition:opacity .2s; color:var(--color-primary); }

.re-two { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
@media (max-width:480px) { .re-two { grid-template-columns:1fr; } }

.re-input-wrap { position:relative; }
.re-input-wrap .re-input { padding-left:42px; }
.re-eye { position:absolute; left:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--color-muted); padding:4px; display:flex; }
.re-eye:hover { color:var(--color-text); }

.re-strength-bar { height:4px; background:var(--color-border); border-radius:4px; margin-top:6px; overflow:hidden; }
.re-strength-fill { height:100%; width:0; border-radius:4px; transition:width .3s, background .3s; }

.re-terms { display:flex; align-items:flex-start; gap:10px; cursor:pointer; padding:12px 14px; background:var(--color-bg-alt); border:1.5px solid var(--color-border); border-radius:10px; }
.re-terms input[type="checkbox"] { width:18px; height:18px; flex-shrink:0; margin-top:1px; accent-color:var(--color-primary); cursor:pointer; }
.re-terms-text { font-size:.84rem; color:var(--color-text); line-height:1.5; }
.re-terms-text a { color:var(--color-primary); text-decoration:underline; }

.re-submit { width:100%; padding:13px 20px; background:var(--color-primary); color:#fff; border:none; border-radius:12px; font-size:1rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:background .15s, opacity .15s; font-family:inherit; }
.re-submit:hover:not(:disabled) { background:var(--color-primary-dark); }
.re-submit:disabled { opacity:.45; cursor:not-allowed; }

.re-footer-link { text-align:center; font-size:.88rem; color:var(--color-muted); padding:0 24px 20px; margin:0; }
.re-footer-link a { color:var(--color-primary); font-weight:600; text-decoration:none; }
.re-footer-link a:hover { text-decoration:underline; }
</style>

<script>
function toggleVis(id, btn) {
  var inp=document.getElementById(id), on=btn.querySelector('.eye-on'), off=btn.querySelector('.eye-off');
  if (inp.type==='password') { inp.type='text'; on.style.display='none'; off.style.display=''; }
  else { inp.type='password'; on.style.display=''; off.style.display='none'; }
}
function checkEmail(inp) {
  var tick=document.getElementById('emailTick');
  tick.textContent=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(inp.value.trim()) ? '✓' : '';
}
function updateStrength(val) {
  var fill=document.getElementById('strengthFill'), label=document.getElementById('strengthLabel');
  var score=0;
  if (val.length>=8) score++; if (/[A-Z]/.test(val)) score++; if (/[0-9]/.test(val)) score++; if (/[^A-Za-z0-9]/.test(val)) score++;
  var map=[{w:'0%',bg:'transparent',txt:'8 حروف على الأقل'},{w:'25%',bg:'#ef4444',txt:'ضعيفة جداً'},{w:'50%',bg:'#f97316',txt:'ضعيفة'},{w:'75%',bg:'#eab308',txt:'متوسطة'},{w:'100%',bg:'#1e7a4c',txt:'قوية 💪'}];
  var m=val.length===0?map[0]:map[score]||map[1];
  fill.style.width=m.w; fill.style.background=m.bg; label.textContent=m.txt; label.style.color=val.length===0?'':m.bg;
}
function checkMatch() {
  var p1=document.getElementById('password').value, p2=document.getElementById('confirmPassword').value, hint=document.getElementById('matchHint');
  if (!p2) { hint.innerHTML='&nbsp;'; return; }
  if (p1===p2) { hint.textContent='✓ كلمتين السر متطابقتين'; hint.style.color='var(--color-primary)'; }
  else { hint.textContent='✗ كلمتين السر مش زي بعض'; hint.style.color='var(--color-danger)'; }
}
function toggleBtn() { document.getElementById('submitBtn').disabled=!document.getElementById('agreeTerms').checked; }
</script>

<%- include('../partials/footer') %>
