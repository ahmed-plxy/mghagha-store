<%- include('../partials/header', { title: store.store_name }) %>
<div class="container">

  <%# ── Store Header Card ── %>
  <div class="sp-header-card">
    <div class="sp-header-body">

      <%# Avatar %>
      <div class="sp-avatar-wrap">
        <% if (store.logo_image) { %>
          <img src="/uploads/<%= store.logo_image %>" alt="<%= store.store_name %>" class="sp-avatar">
        <% } else { %>
          <div class="sp-avatar-fallback"><%= store.store_name.charAt(0) %></div>
        <% } %>
      </div>

      <%# Store Info %>
      <div class="sp-info-block">
        <div class="sp-name-rating-row">
          <h1 class="sp-store-name"><%= store.store_name %></h1>
          <% if (store.rating_average > 0) { %>
            <span class="sp-rating-badge">★ <%= store.rating_average.toFixed(1) %></span>
          <% } %>
        </div>
        <div class="sp-meta-row">
          <span class="sp-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= store.area_name %>
          </span>
          <span class="sp-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            عضو منذ <%= new Date(store.created_at).getFullYear() %>
          </span>
        </div>
        <% if (store.description) { %>
          <p class="sp-description"><%= store.description %></p>
        <% } %>
      </div>

    </div>

    <%# ── Communication Action Buttons ── %>
    <div class="sp-action-row">

      <%# WhatsApp — PRIMARY %>
      <% if (store.owner_phone && !store.owner_phone.startsWith('google_')) { %>
        <a href="https://wa.me/<%= store.owner_phone.replace(/^0/, '20') %>?text=<%= encodeURIComponent('مرحباً، رأيت متجرك ' + store.store_name + ' على منصة مغاغة') %>"
           class="sp-btn-whatsapp" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          واتساب البائع
        </a>
      <% } %>

      <%# In-App Chat — SECONDARY %>
      <% if (currentUser && currentUser.role === 'customer') { %>
        <form action="/customer/messages/start" method="POST" class="sp-action-chat-form">
          <input type="hidden" name="storeId" value="<%= store.id %>">
          <button type="submit" class="sp-btn-chat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="17" height="17"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            محادثة داخلية
          </button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="sp-btn-chat" style="text-decoration:none;text-align:center;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="17" height="17"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          سجل للتواصل
        </a>
      <% } %>

    </div>
  </div>

  <%# ── Products Grid ── %>
  <h2 class="sp-products-title">منتجات المتجر <span class="sp-count">(<%= products.length %>)</span></h2>
  <% if (products.length === 0) { %>
    <div class="sp-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
      <p>لا توجد منتجات متاحة حاليًا في هذا المتجر.</p>
    </div>
  <% } else { %>
    <div class="sp-grid">
      <% products.forEach(function(product) { %>
        <a href="/stores/<%= store.store_slug %>/products/<%= product.slug %>" class="sp-product-card">
          <div class="sp-product-img-wrap">
            <% if (product.image_url) { %>
              <img src="/uploads/<%= product.image_url %>" alt="<%= product.name %>">
            <% } else { %>
              <div class="sp-product-no-img">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            <% } %>
          </div>
          <div class="sp-product-body">
            <p class="sp-product-name"><%= product.name %></p>
            <p class="sp-product-price"><%= product.price.toFixed(0) %> <span>ج.م</span></p>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

</div>

<style>
/* ── Header Card ── */
.sp-header-card {
  border: 1.5px solid var(--color-border);
  border-radius: 18px;
  overflow: hidden;
  margin-bottom: 24px;
  background: var(--color-bg);
}
.sp-header-body {
  display: flex; gap: 14px; padding: 16px; align-items: flex-start;
}
.sp-avatar-wrap { flex-shrink: 0; }
.sp-avatar {
  width: 64px; height: 64px;
  border-radius: 14px;
  object-fit: cover;
  border: 2px solid var(--color-border);
  display: block;
}
.sp-avatar-fallback {
  width: 64px; height: 64px;
  border-radius: 14px;
  background: var(--color-primary);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; font-weight: 800;
}
.sp-info-block { flex: 1; }
.sp-name-rating-row {
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  margin-bottom: 5px;
}
.sp-store-name { font-size: 1.2rem; font-weight: 800; margin: 0; }
.sp-rating-badge {
  background: #fef3c7; color: #92400e;
  border-radius: 20px; padding: 2px 9px;
  font-size: .78rem; font-weight: 700; flex-shrink: 0;
}
.sp-meta-row { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 8px; }
.sp-meta-item {
  display: flex; align-items: center; gap: 4px;
  font-size: .8rem; color: var(--color-muted);
}
.sp-description {
  font-size: .86rem; color: var(--color-muted);
  line-height: 1.5; margin: 0;
}

/* ── Communication Action Buttons ── */
.sp-action-row {
  display: flex; gap: 10px; padding: 0 16px 16px; align-items: stretch;
}
.sp-action-chat-form { flex: 1; }

/* WhatsApp = PRIMARY (full text, green) */
.sp-btn-whatsapp {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px;
  background: #25d366; color: #fff; font-weight: 700; font-size: .92rem;
  border-radius: 12px; padding: 12px 14px; text-decoration: none;
  transition: background .18s; font-family: inherit;
}
.sp-btn-whatsapp:hover { background: #1fba58; color: #fff; text-decoration: none; }

/* Chat = SECONDARY (outline) */
.sp-btn-chat {
  width: 100%; display: flex; align-items: center; justify-content: center; gap: 7px;
  background: var(--color-bg-alt); color: var(--color-text);
  border: 1.5px solid var(--color-border); border-radius: 12px;
  padding: 12px 14px; font-size: .92rem; font-weight: 700;
  cursor: pointer; transition: border-color .18s, color .18s; font-family: inherit;
}
.sp-btn-chat:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }

/* Desktop: side-by-side equal width */
@media (min-width: 600px) {
  .sp-action-row { flex-direction: row; }
  .sp-btn-whatsapp, .sp-action-chat-form, .sp-btn-chat { flex: 1; }
}

/* ── Products Grid ── */
.sp-products-title {
  font-size: 1.05rem; font-weight: 800; margin: 0 0 14px;
}
.sp-count {
  font-size: .85rem; font-weight: 600; color: var(--color-muted);
}
.sp-empty {
  text-align: center; padding: 48px 16px;
  color: var(--color-muted);
  display: flex; flex-direction: column; align-items: center; gap: 12px;
}

/* Uniform 1:1 grid */
.sp-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 480px) {
  .sp-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 768px) {
  .sp-grid { grid-template-columns: repeat(4, 1fr); }
}

.sp-product-card {
  border: 1.5px solid var(--color-border);
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  color: var(--color-text);
  background: var(--color-bg);
  transition: border-color .18s, box-shadow .18s;
  display: flex;
  flex-direction: column;
}
.sp-product-card:hover {
  border-color: var(--color-primary);
  box-shadow: 0 4px 16px rgba(0,0,0,.08);
}

/* Strict 1:1 square image */
.sp-product-img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--color-bg-alt);
  overflow: hidden;
  flex-shrink: 0;
}
.sp-product-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .25s;
}
.sp-product-card:hover .sp-product-img-wrap img {
  transform: scale(1.04);
}
.sp-product-no-img {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-muted);
}

.sp-product-body {
  padding: 10px;
  flex: 1;
}
.sp-product-name {
  font-size: .85rem; font-weight: 700;
  margin: 0 0 4px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.sp-product-price {
  font-size: .9rem; font-weight: 800;
  color: var(--color-primary); margin: 0;
}
.sp-product-price span {
  font-size: .78rem; font-weight: 600;
}
</style>

<%- include('../partials/footer') %>
