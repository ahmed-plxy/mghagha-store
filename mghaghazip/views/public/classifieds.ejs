<%- include('../partials/header', { title: title }) %>

<div class="products-page">

  <div class="landing-search-bar">
    <div class="landing-search-inner">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <div class="search-input-wrapper">
        <form action="/classifieds" method="GET" id="classifiedSearchForm">
          <input type="text" name="search" class="landing-search-input" value="<%= filters.search %>" placeholder="ابحث في المستعمل..." autocomplete="off">
          <% if (filters.categoryId) { %><input type="hidden" name="categoryId" value="<%= filters.categoryId %>"><% } %>
        </form>
      </div>
    </div>
  </div>

  <% if (popularSearches && popularSearches.length > 0) { %>
  <div class="container" style="padding-top:14px;padding-bottom:0;">
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
      <span style="font-size:.85rem;color:var(--color-muted);font-weight:600;">🔥 الأكثر بحثًا:</span>
      <% popularSearches.forEach(function(ps) { %>
        <a href="/classifieds?search=<%= encodeURIComponent(ps.term) %>" class="subcategory-chip" style="font-size:.82rem;"><%= ps.term %></a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <div class="container">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px;">
      <div>
        <h1 style="font-size:1.3rem;font-weight:800;margin:0 0 4px;">🏷️ بيع وشراء مستعمل في مغاغة</h1>
        <p style="color:var(--color-muted);margin:0;font-size:.88rem;"><%= listings.length %> إعلان متاح</p>
      </div>
      <% if (currentUser && currentUser.role === 'customer') { %>
      <a href="/customer/sell" class="btn btn-primary" style="font-size:.9rem;">+ بيع حاجة</a>
      <% } else if (!currentUser) { %>
      <a href="/auth/login" class="btn btn-primary" style="font-size:.9rem;">سجل للبيع</a>
      <% } %>
    </div>

    <div class="subcategory-chips-bar" style="margin-bottom:20px;overflow-x:auto;white-space:nowrap;display:flex;gap:8px;">
      <a href="/classifieds<%= filters.search ? '?search='+encodeURIComponent(filters.search) : '' %>" class="subcategory-chip <%= !filters.categoryId ? 'active' : '' %>">الكل</a>
      <% categories.forEach(function(cat) { %>
        <a href="/classifieds?categoryId=<%= cat.id %><%= filters.search ? '&search='+encodeURIComponent(filters.search) : '' %>" class="subcategory-chip <%= Number(filters.categoryId) === cat.id ? 'active' : '' %>"><%= cat.name %></a>
      <% }) %>
    </div>

    <% if (listings.length === 0) { %>
    <div style="text-align:center;padding:60px 20px;color:var(--color-muted);">
      <div style="font-size:3rem;margin-bottom:16px;">🔍</div>
      <p style="font-size:1.1rem;font-weight:700;">مفيش إعلانات دلوقتي</p>
      <% if (currentUser && currentUser.role === 'customer') { %>
        <p>كن أول واحد ينشر إعلان!</p>
        <a href="/customer/sell" class="btn btn-primary" style="margin-top:12px;">انشر إعلانك</a>
      <% } %>
    </div>
    <% } else { %>
    <div class="grid">
      <% listings.forEach(function(listing) { %>
      <a href="/classifieds/<%= listing.slug %>" class="card-link" style="position:relative;">
        <% if (listing.status === 'sold') { %>
          <div style="position:absolute;top:10px;right:10px;z-index:2;background:rgba(0,0,0,.55);color:#fff;font-size:.75rem;font-weight:700;padding:3px 10px;border-radius:20px;">متباع</div>
        <% } %>
        <% if (listing.images && listing.images.length > 0) { %>
          <img src="/uploads/<%= listing.images[0].image_url %>" class="card-image" alt="<%= listing.name %>" loading="lazy">
        <% } else { %>
          <div class="card-image-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        <% } %>
        <div class="card-body">
          <p class="card-title"><%= listing.name %></p>
          <p class="card-price"><%= listing.price > 0 ? listing.price.toFixed(0)+' جنيه' : 'السعر قابل للتفاوض' %></p>
          <p class="card-meta"><%= listing.category_name || '' %> · <%= listing.seller_name %></p>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

  </div>
</div>

<%- include('../partials/footer') %>
