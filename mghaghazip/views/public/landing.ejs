<%- include('../partials/header', { title: t('app.name') }) %>

<div class="landing-page">

  <div class="landing-hero-banner">
    <div class="landing-hero-inner container">
      <p class="landing-hero-badge">📍 مغاغة — المنيا</p>
      <h1 class="landing-hero-title">سوق مغاغة المحلي</h1>
      <p class="landing-hero-sub">بيع واشتري من الجيران · عروض يومية · منتجات محلية أصيلة</p>
    </div>
  </div>

  <% if (activeBanners && activeBanners.length > 0) { %>
  <div class="banner-carousel-section">
    <div class="banner-carousel" id="bannerCarousel">
      <div class="banner-slides" id="bannerSlides">
        <% activeBanners.forEach(function(banner, idx) { %>
          <div class="banner-slide <%= idx === 0 ? 'active' : '' %>">
            <% if (banner.link_url) { %>
              <a href="<%= banner.link_url %>" target="_blank" rel="noopener noreferrer">
                <img src="/public<%= banner.image_url %>" alt="<%= banner.title || 'إعلان ممول' %>" class="banner-slide-img">
              </a>
            <% } else { %>
              <img src="/public<%= banner.image_url %>" alt="<%= banner.title || 'إعلان ممول' %>" class="banner-slide-img">
            <% } %>
            <% if (banner.title) { %>
              <div class="banner-slide-label"><%= banner.title %></div>
            <% } %>
          </div>
        <% }) %>
      </div>
      <% if (activeBanners.length > 1) { %>
        <button class="banner-nav banner-nav-prev" onclick="bannerNav(-1)" aria-label="السابق">‹</button>
        <button class="banner-nav banner-nav-next" onclick="bannerNav(1)" aria-label="التالي">›</button>
        <div class="banner-dots">
          <% activeBanners.forEach(function(_, idx) { %>
            <span class="banner-dot <%= idx === 0 ? 'active' : '' %>" onclick="bannerGoTo(<%= idx %>)"></span>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="landing-search-bar">
    <div class="landing-search-inner">
      <svg class="search-icon" id="landingSearchIconBtn" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="button" tabindex="0" aria-label="بحث" style="cursor:pointer;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <div class="animated-placeholder-wrap" id="landingPlaceholderWrap">
        <span class="animated-placeholder" id="landingPlaceholderText">بتدور على إيه؟</span>
      </div>
      <input type="text" id="landingSearch" class="landing-search-input" autocomplete="off" onkeydown="if(event.key==='Enter'){window.location='/products?search='+encodeURIComponent(this.value)}">
      <div class="search-suggestions" id="searchSuggestions">
        <a href="/products?search=سيارة" class="search-suggestion-item">🚗 سيارة مستعملة في مغاغة</a>
        <a href="/products?search=موبايل" class="search-suggestion-item">📱 موبايل مستعمل</a>
        <a href="/products?search=ثلاجة" class="search-suggestion-item">❄️ ثلاجة مستعملة في مغاغة</a>
        <a href="/products?search=أرانب" class="search-suggestion-item">🐇 أرانب ومواشي</a>
        <a href="/products?search=شقة" class="search-suggestion-item">🏠 شقة للإيجار</a>
        <a href="/products?search=طماطم" class="search-suggestion-item">🍅 محصول طماطم</a>
        <a href="/products?search=دراجة" class="search-suggestion-item">🚲 دراجة مستعملة</a>
        <a href="/products?search=أثاث" class="search-suggestion-item">🛋️ أثاث منزلي</a>
      </div>
    </div>
  </div>

  <div class="landing-categories container">
    <h2 class="section-title">تصفح حسب الفئة</h2>
    <div class="category-icon-grid">
      <% mainCategories.forEach(function(cat) { %>
        <a href="/products?categoryId=<%= cat.id %>" class="category-icon-item">
          <div class="category-icon-circle">
            <%- cat.icon %>
          </div>
          <span class="category-icon-label"><%= cat.name %></span>
        </a>
      <% }) %>
    </div>
  </div>

  <% const categoryKeys = Object.keys(productsByCategory); %>
  <% if (categoryKeys.length > 0) { %>
    <% categoryKeys.forEach(function(catId) { %>
      <% const group = productsByCategory[catId]; %>
      <div class="offers-section">
        <div class="offers-section-header container">
          <h2 class="section-title"><%= group.category.name %></h2>
          <a href="/products?categoryId=<%= catId %>" class="view-all-link">عرض الكل ←</a>
        </div>
        <div class="offers-carousel-wrapper">
          <div class="offers-carousel">
            <% group.products.forEach(function(product) { %>
              <a href="/stores/<%= product.store_slug %>/products/<%= product.slug %>" class="offer-card">
                <div class="offer-card-image-wrap">
                  <% if (product.image_url) { %>
                    <img src="/uploads/<%= product.image_url %>" alt="<%= product.name %>" class="offer-card-image">
                  <% } else { %>
                    <div class="offer-card-image offer-card-no-image">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                  <% } %>
                </div>
                <div class="offer-card-body">
                  <p class="offer-card-name"><%= product.name %></p>
                  <p class="offer-card-store"><%= product.store_name %></p>
                  <p class="offer-card-price"><%= product.price.toFixed(0) %> <span class="price-unit">ج.م</span></p>
                </div>
              </a>
            <% }) %>
            <a href="/products?categoryId=<%= catId %>" class="offer-card offer-card-viewall">
              <span>عرض المزيد من<br><%= group.category.name %></span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="28" height="28"><polyline points="15 18 9 12 15 6"/></svg>
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="container">
      <div class="empty-offers-msg">
        <p>لسه مفيش عروض. تصفح المحلات وشوف إيه المتاح.</p>
        <a href="/stores" class="btn btn-primary">تصفح المحلات</a>
      </div>
    </div>
  <% } %>

  <% if (featuredStores.length > 0) { %>
  <div class="offers-section">
    <div class="offers-section-header container">
      <h2 class="section-title">🏪 متاجر مميزة في مغاغة</h2>
      <a href="/stores" class="view-all-link">عرض الكل ←</a>
    </div>
    <div class="offers-carousel-wrapper">
      <div class="offers-carousel">
        <% featuredStores.forEach(function(store) { %>
          <a href="/stores/<%= store.store_slug %>" class="offer-card store-card">
            <div class="offer-card-image-wrap">
              <% var storeImg = store.logo_image || store.cover_image; %>
              <% if (storeImg) { %>
                <img src="/uploads/<%= storeImg %>" alt="<%= store.store_name %>" class="offer-card-image" style="object-fit:cover;">
              <% } else { %>
                <div class="offer-card-image offer-card-no-image">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
                </div>
              <% } %>
            </div>
            <div class="offer-card-body">
              <p class="offer-card-name"><%= store.store_name %></p>
              <p class="offer-card-store"><%= store.area_name || 'مغاغة' %></p>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <% if (popularSearches && popularSearches.length > 0) { %>
  <div class="popular-searches container">
    <h2 class="section-title">🔍 عمليات البحث الشائعة</h2>
    <div class="popular-searches-list">
      <% popularSearches.forEach(function(s) { %>
        <a href="/products?search=<%= encodeURIComponent(s.term) %>" class="popular-search-tag"><%= s.term %></a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (recentClassifieds && recentClassifieds.length > 0) { %>
  <div class="container" style="margin-bottom:32px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
      <h2 class="section-title" style="margin:0;">🏷️ أحدث إعلانات المستعمل</h2>
      <a href="/classifieds" style="font-size:.88rem;color:var(--color-primary);font-weight:700;text-decoration:none;">شوف الكل ←</a>
    </div>
    <div class="grid">
      <% recentClassifieds.forEach(function(listing) { %>
      <a href="/classifieds/<%= listing.slug %>" class="card-link">
        <% if (listing.images && listing.images.length > 0) { %>
          <img src="/uploads/<%= listing.images[0].image_url %>" class="card-image" alt="<%= listing.name %>" loading="lazy">
        <% } else { %>
          <div class="card-image-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        <% } %>
        <div class="card-body">
          <p class="card-title"><%= listing.name %></p>
          <p class="card-price"><%= listing.price > 0 ? listing.price.toFixed(0)+' جنيه' : 'قابل للتفاوض' %></p>
          <p class="card-meta"><%= listing.seller_name %></p>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (!currentUser || currentUser.role === 'customer' || !currentUser.role) { %>
  <div class="landing-sell-cta container">
    <div class="landing-sell-cta-inner">
      <div class="landing-sell-cta-text">
        <h2>هل عندك شيء تبيعه؟</h2>
        <p>بيع حاجاتك المستعملة أو افتح متجرك في مغاغة النهارده</p>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <a href="/customer/sell" class="btn btn-primary">بيع حاجة مستعملة</a>
        <a href="/vendor/apply" class="btn" style="background:rgba(255,255,255,.15);color:#fff;border:1.5px solid rgba(255,255,255,.4);">افتح متجر</a>
      </div>
    </div>
  </div>
  <% } %>

</div>

<script>
(function() {
  var input = document.getElementById('landingSearch');
  var wrap = document.getElementById('landingPlaceholderWrap');
  var span = document.getElementById('landingPlaceholderText');
  var suggestions = document.getElementById('searchSuggestions');
  var placeholders = [
    'بتدور على إيه؟',
    'بتدور على عربية مستعملة؟',
    'بتدور على موبايل؟',
    'بتدور على أثاث؟',
    'بتدور على منتجات زراعية؟',
    'بتدور على أرض؟',
    'بتدور على حيوان؟',
    'بتدور على تلاجة مستعملة؟'
  ];
  var pi = 0;

  setInterval(function() {
    span.classList.add('ph-exit');
    setTimeout(function() {
      pi = (pi + 1) % placeholders.length;
      span.textContent = placeholders[pi];
      span.classList.remove('ph-exit');
      span.classList.add('ph-enter');
      setTimeout(function() { span.classList.remove('ph-enter'); }, 400);
    }, 300);
  }, 2800);

  input.addEventListener('focus', function() {
    suggestions.style.display = 'block';
    wrap.style.display = 'none';
  });

  input.addEventListener('blur', function() {
    setTimeout(function() { suggestions.style.display = 'none'; }, 150);
    if (!input.value) wrap.style.display = 'flex';
  });
  input.addEventListener('input', function() {
    if (this.value.trim()) {
      suggestions.style.display = 'none';
      wrap.style.display = 'none';
    } else {
      suggestions.style.display = 'block';
      wrap.style.display = 'flex';
    }
  });
  document.addEventListener('click', function(e) {
    if (!input.contains(e.target) && !suggestions.contains(e.target)) {
      suggestions.style.display = 'none';
    }
  });

  // Search only runs on Enter or when the search icon is clicked — no live auto-search.
  var landingSearchIconBtn = document.getElementById('landingSearchIconBtn');
  function runLandingSearch() {
    if (input.value.trim()) {
      window.location = '/products?search=' + encodeURIComponent(input.value);
    }
  }
  if (landingSearchIconBtn) {
    landingSearchIconBtn.addEventListener('click', runLandingSearch);
    landingSearchIconBtn.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        runLandingSearch();
      }
    });
  }
})();
</script>

<style>
.banner-carousel-section {
  padding: 12px 0 0;
}
.banner-carousel {
  position: relative;
  width: 100%;
  max-width: 960px;
  margin: 0 auto;
  border-radius: 18px;
  overflow: hidden;
  background: var(--color-bg-alt);
  box-shadow: 0 4px 24px rgba(0,0,0,0.10);
}
.banner-slides {
  display: flex;
  transition: transform 0.45s cubic-bezier(.4,0,.2,1);
}
.banner-slide {
  min-width: 100%;
  position: relative;
}
.banner-slide-img {
  width: 100%;
  max-height: 260px;
  object-fit: cover;
  display: block;
}
.banner-slide-label {
  position: absolute;
  bottom: 0;
  right: 0;
  left: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.55));
  color: #fff;
  padding: 18px 16px 12px;
  font-size: 0.95rem;
  font-weight: 700;
}
.banner-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.38);
  color: #fff;
  border: none;
  border-radius: 50%;
  width: 38px;
  height: 38px;
  font-size: 1.4rem;
  cursor: pointer;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  transition: background 0.2s;
}
.banner-nav:hover { background: rgba(0,0,0,0.6); }
.banner-nav-prev { left: 10px; }
.banner-nav-next { right: 10px; }
.banner-dots {
  position: absolute;
  bottom: 8px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 6px;
  z-index: 2;
}
.banner-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.55);
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.banner-dot.active {
  background: #fff;
  transform: scale(1.25);
}
</style>
<script>
(function() {
  const slides = document.getElementById('bannerSlides');
  if (!slides) return;
  const dots = document.querySelectorAll('.banner-dot');
  let current = 0;
  const total = slides.children.length;
  const isRtl = document.documentElement.dir === 'rtl' || document.body.dir === 'rtl';
  function go(idx) {
    current = (idx + total) % total;
    const factor = isRtl ? 100 : -100;
    slides.style.transform = 'translateX(' + (current * factor) + '%)';
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }
  window.bannerNav = function(dir) { go(current + dir); };
  window.bannerGoTo = function(idx) { go(idx); };
  if (total > 1) {
    setInterval(function() { go(current + 1); }, 4500);
  }
})();
</script>
<%- include('../partials/footer') %>
