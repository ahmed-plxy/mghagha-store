<%- include('../partials/header', { title: 'المتاجر' }) %>
<div class="container">
  <h1>المتاجر</h1>
  <table class="data-table">
    <thead><tr><th>المتجر</th><th>المالك</th><th>المنطقة</th><th>الحالة</th><th>الإجراء</th></tr></thead>
    <tbody>
      <% stores.forEach(function(store) { %>
        <tr>
          <td><%= store.store_name %></td>
          <td><%= store.owner_name %> (<%= store.owner_phone %>)</td>
          <td><%= store.area_name %></td>
          <td><span class="badge badge-<%= store.status === 'active' ? 'success' : 'muted' %>"><%= store.status === 'active' ? 'نشط' : 'معلّق' %></span></td>
          <td class="actions-cell">
            <a href="/admin/stores/<%= store.id %>/products" class="btn btn-small btn-secondary">المنتجات</a>
            <% if (store.status === 'active') { %>
              <form action="/admin/stores/<%= store.id %>/suspend" method="POST" class="inline-form">
                <button type="submit" class="btn btn-small btn-danger">تعليق</button>
              </form>
            <% } else { %>
              <form action="/admin/stores/<%= store.id %>/activate" method="POST" class="inline-form">
                <button type="submit" class="btn btn-small btn-secondary">تفعيل</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
