<%- include('../partials/header', { title: 'لوحة تحكم الإدارة' }) %>
<div class="container">

  <div class="page-header-row" style="margin-bottom:22px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.5rem;">لوحة تحكم الإدارة</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">مرحباً، مدير النظام</p>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="stats-grid" style="gap:12px;margin-bottom:28px;">
    <a href="/admin/vendor-applications?status=pending" class="stat-card" style="text-decoration:none;flex:1;min-width:140px;">
      <div class="stat-card-icon" style="background:#fff8e1;">📋</div>
      <span class="stat-number" style="color:<%= pendingCount > 0 ? 'var(--color-danger)' : 'var(--color-primary-dark)' %>"><%= pendingCount %></span>
      <span class="stat-label">طلبات بائعين قيد المراجعة</span>
    </a>
    <a href="/admin/stores" class="stat-card" style="text-decoration:none;flex:1;min-width:140px;">
      <div class="stat-card-icon" style="background:#e3f3ea;">🏪</div>
      <span class="stat-number"><%= storeCount %></span>
      <span class="stat-label">المتاجر النشطة</span>
    </a>
    <div class="stat-card" style="flex:1;min-width:140px;">
      <div class="stat-card-icon" style="background:#e8f0fe;">👤</div>
      <span class="stat-number"><%= customerCount %></span>
      <span class="stat-label">العملاء المسجلون</span>
    </div>
    <a href="/admin/orders" class="stat-card" style="text-decoration:none;flex:1;min-width:140px;">
      <div class="stat-card-icon" style="background:#fce8f3;">📦</div>
      <span class="stat-number"><%= todayOrderCount %></span>
      <span class="stat-label">طلبات اليوم</span>
    </a>
  </div>

  <!-- Quick Actions -->
  <div class="pf-section" style="margin-bottom:20px;">
    <div class="pf-section-title">
      <span>⚡</span>
      <span>الإجراءات السريعة</span>
    </div>
    <div class="admin-quick-actions">
      <a href="/admin/vendor-applications" class="admin-action-card">
        <span class="admin-action-icon">👥</span>
        <span class="admin-action-label">طلبات البائعين</span>
        <% if (pendingCount > 0) { %>
          <span class="badge badge-danger" style="background:var(--color-danger);color:#fff;margin-top:4px;"><%= pendingCount %> جديد</span>
        <% } %>
      </a>
      <a href="/admin/stores" class="admin-action-card">
        <span class="admin-action-icon">🏪</span>
        <span class="admin-action-label">إدارة المتاجر</span>
      </a>
      <a href="/admin/orders" class="admin-action-card">
        <span class="admin-action-icon">📦</span>
        <span class="admin-action-label">إدارة الطلبات</span>
      </a>
      <a href="/admin/reviews" class="admin-action-card">
        <span class="admin-action-icon">⭐</span>
        <span class="admin-action-label">مراجعة التقييمات</span>
      </a>
      <a href="/admin/banners" class="admin-action-card">
        <span class="admin-action-icon">🖼️</span>
        <span class="admin-action-label">الإعلانات الممولة</span>
      </a>
      <a href="/admin/popular-searches" class="admin-action-card">
        <span class="admin-action-icon">🔎</span>
        <span class="admin-action-label">الكلمات الشائعة</span>
      </a>
      <a href="/admin/flagged-chats" class="admin-action-card">
        <span class="admin-action-icon">🚨</span>
        <span class="admin-action-label">محادثات مشبوهة</span>
        <% if (flaggedCount > 0) { %>
          <span class="badge badge-danger" style="background:var(--color-danger);color:#fff;margin-top:4px;"><%= flaggedCount %></span>
        <% } %>
      </a>
      <a href="/admin/classifieds-moderation" class="admin-action-card">
        <span class="admin-action-icon">📋</span>
        <span class="admin-action-label">إشراف الإعلانات</span>
      </a>
      <a href="/admin/push-notifications" class="admin-action-card">
        <span class="admin-action-icon">🔔</span>
        <span class="admin-action-label">إشعارات الموبايل</span>
      </a>
      <a href="/admin/app-version" class="admin-action-card">
        <span class="admin-action-icon">📱</span>
        <span class="admin-action-label">إصدار التطبيق</span>
      </a>
    </div>
  </div>

  <% if (pendingCount > 0) { %>
  <div class="info-card" style="border-right:4px solid var(--color-danger);background:var(--color-danger-tint);margin-bottom:16px;">
    <p style="margin:0;font-weight:600;">
      ⚠ يوجد <strong style="color:var(--color-danger);"><%= pendingCount %></strong> طلب انضمام بائع بانتظار مراجعتك.
      <a href="/admin/vendor-applications?status=pending" style="color:var(--color-primary);margin-right:8px;">مراجعة الطلبات ←</a>
    </p>
  </div>
  <% } %>

  <% if (flaggedCount > 0) { %>
  <div class="info-card" style="border-right:4px solid #f97316;background:#fff7ed;margin-bottom:16px;">
    <p style="margin:0;font-weight:600;">
      🚨 يوجد <strong style="color:#f97316;"><%= flaggedCount %></strong> محادثة مشبوهة تحتاج مراجعة.
      <a href="/admin/flagged-chats" style="color:var(--color-primary);margin-right:8px;">مراجعة الشات ←</a>
    </p>
  </div>
  <% } %>

  <!-- Top Selling Products -->
  <div class="pf-section" style="margin-bottom:24px;">
    <div class="pf-section-title">
      <span>🔥</span>
      <span>المنتجات الأكثر مبيعاً</span>
    </div>
    <% if (topProducts.length === 0) { %>
      <div style="text-align:center;padding:32px 20px;color:var(--color-muted);">
        <p style="font-size:1.8rem;margin-bottom:8px;">📊</p>
        <p>لا توجد بيانات مبيعات بعد. ستظهر هنا بعد اكتمال أول طلب.</p>
      </div>
    <% } else { %>
      <div style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width:36px;">#</th>
              <th>المنتج</th>
              <th>المتجر</th>
              <th style="text-align:center;">الوحدات المباعة</th>
              <th style="text-align:left;">إجمالي الإيرادات</th>
            </tr>
          </thead>
          <tbody>
            <% topProducts.forEach(function(p, i) { %>
              <tr>
                <td style="font-weight:700;color:<%= i === 0 ? '#f59e0b' : i === 1 ? '#94a3b8' : i === 2 ? '#b45309' : 'var(--color-muted)' %>;">
                  <%= i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : (i + 1) %>
                </td>
                <td>
                  <div style="display:flex;align-items:center;gap:10px;">
                    <% if (p.image_url) { %>
                      <img src="/uploads/<%= p.image_url %>" alt="" style="width:36px;height:36px;border-radius:8px;object-fit:cover;flex-shrink:0;">
                    <% } else { %>
                      <div style="width:36px;height:36px;border-radius:8px;background:var(--color-bg-alt);display:flex;align-items:center;justify-content:center;font-size:1rem;">📦</div>
                    <% } %>
                    <span style="font-weight:600;"><%= p.name %></span>
                  </div>
                </td>
                <td style="color:var(--color-muted);font-size:0.88rem;"><%= p.store_name %></td>
                <td style="text-align:center;">
                  <span class="badge badge-success" style="font-size:0.9rem;padding:4px 10px;"><%= p.total_sold %> وحدة</span>
                </td>
                <td style="font-weight:700;color:var(--color-primary-dark);text-align:left;">
                  <%= p.total_revenue.toFixed(2) %> ج.م
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

</div>
<%- include('../partials/footer') %>
