<%- include('../partials/header', { title: 'تقييمات المنتجات' }) %>
<div class="container">
  <h1>تقييمات المنتجات</h1>

  <div class="tabs">
    <a href="/admin/reviews" class="<%= currentStatus === 'all' ? 'tab active' : 'tab' %>">الكل</a>
    <a href="/admin/reviews?status=approved" class="<%= currentStatus === 'approved' ? 'tab active' : 'tab' %>">ظاهر</a>
    <a href="/admin/reviews?status=hidden" class="<%= currentStatus === 'hidden' ? 'tab active' : 'tab' %>">مخفي</a>
  </div>

  <% if (reviews.length === 0) { %>
    <p>لا توجد تقييمات.</p>
  <% } else { %>
    <table class="data-table">
      <thead><tr><th>المنتج</th><th>المُقيّم</th><th>التقييم</th><th>التعليق</th><th>الحالة</th><th>الإجراء</th></tr></thead>
      <tbody>
        <% reviews.forEach(function(review) { %>
          <tr>
            <td><%= review.product_name %></td>
            <td><%= review.reviewer_name %></td>
            <td class="review-stars"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></td>
            <td><%= review.comment || '—' %></td>
            <td><span class="badge badge-<%= review.status === 'approved' ? 'success' : 'muted' %>"><%= review.status === 'approved' ? 'ظاهر' : 'مخفي' %></span></td>
            <td>
              <% if (review.status === 'approved') { %>
                <form action="/admin/reviews/<%= review.id %>/hide" method="POST" class="inline-form">
                  <button type="submit" class="btn btn-small btn-danger">إخفاء</button>
                </form>
              <% } else { %>
                <form action="/admin/reviews/<%= review.id %>/unhide" method="POST" class="inline-form">
                  <button type="submit" class="btn btn-small btn-secondary">إظهار</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../partials/footer') %>
