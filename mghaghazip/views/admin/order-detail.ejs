<%- include('../partials/header', { title: 'تفاصيل الطلب' }) %>
<div class="container">
  <h1>تفاصيل الطلب <%= order.order_number %></h1>

  <div class="info-card">
    <p><strong>المتجر:</strong> <%= order.store_name %></p>
    <p><strong>العميل:</strong> <%= order.customer_name %> (<%= order.customer_phone %>)</p>
    <p><strong>الحالة:</strong> <span class="badge badge-success"><%= orderStatusLabel(order.order_status) %></span></p>
    <p><strong>عنوان التوصيل:</strong> <%= order.customer_address %></p>
  </div>

  <table class="data-table">
    <thead><tr><th>المنتج</th><th>الكمية</th><th>السعر</th><th>الإجمالي</th></tr></thead>
    <tbody>
      <% items.forEach(function(item) { %>
        <tr>
          <td><%= item.product_name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.unit_price.toFixed(2) %> ج.م</td>
          <td><%= item.subtotal.toFixed(2) %> ج.م</td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <p style="text-align:left; font-weight:700; margin-top:10px;">الإجمالي: <%= order.total_amount.toFixed(2) %> ج.م</p>
  <a href="/admin/orders" class="btn btn-secondary">رجوع إلى جميع الطلبات</a>
</div>
<%- include('../partials/footer') %>
