<%- include('../partials/header', { title: 'تفاصيل المحادثة المشبوهة' }) %>
<div class="container">
  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">🔍 تفاصيل المحادثة</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">
        سبب التبليغ:
        <strong style="color:#c2410c;"><%= conversation.flagged_reason || 'محتوى مشبوه' %></strong>
      </p>
    </div>
    <a href="/admin/flagged-chats" class="btn btn-secondary btn-small">← رجوع</a>
  </div>

  <div class="info-card" style="border-right:4px solid #f97316;background:#fff7ed;margin-bottom:20px;">
    <p style="margin:0;font-size:0.9rem;">
      🚨 هذه المحادثة بين <strong><%= conversation.customer_name %></strong> ومتجر <strong><%= conversation.store_name %></strong>
    </p>
  </div>

  <div class="chat-messages-admin" style="background:var(--color-bg-alt);border-radius:14px;padding:16px;max-height:60vh;overflow-y:auto;display:flex;flex-direction:column;gap:10px;margin-bottom:20px;">
    <% if (!messages || messages.length === 0) { %>
      <p style="text-align:center;color:var(--color-muted);padding:24px 0;">لا توجد رسائل.</p>
    <% } else { %>
      <% messages.forEach(function(msg) { %>
        <%
          const isFlagged = (function() {
            const banned = ["نصب","احتيال","نصاب","رقم بطاقة","pin","cvv","otp","بيتكوين","paypal","تحويل فوري","ربح سريع","فزت","جايزة"];
            const lower = (msg.body || '').toLowerCase();
            return banned.some(w => lower.includes(w.toLowerCase()));
          })();
        %>
        <div style="background:<%= isFlagged ? '#fff7ed' : 'var(--color-bg)' %>;border:1px solid <%= isFlagged ? '#fed7aa' : 'var(--color-border)' %>;border-radius:10px;padding:10px 14px;max-width:85%;">
          <div style="font-size:0.78rem;font-weight:700;color:<%= isFlagged ? '#c2410c' : 'var(--color-muted)' %>;margin-bottom:4px;">
            <%= isFlagged ? '🚩 ' : '' %><%= msg.sender_name %>
            <span style="font-weight:400;margin-right:8px;"><%= msg.created_at %></span>
          </div>
          <p style="margin:0;word-break:break-word;font-size:0.92rem;"><%= msg.body %></p>
        </div>
      <% }) %>
    <% } %>
  </div>

  <div style="display:flex;gap:12px;flex-wrap:wrap;">
    <form action="/admin/flagged-chats/<%= conversation.id %>/unflag" method="POST"
      onsubmit="return confirm('هل تؤكد أن هذه المحادثة آمنة؟')">
      <button type="submit" class="btn btn-primary">✓ المحادثة آمنة — إزالة من المشبوهة</button>
    </form>
    <a href="/admin/flagged-chats" class="btn btn-secondary">إلغاء</a>
  </div>
</div>
<%- include('../partials/footer') %>
