<%- include('../partials/header', { title: 'إدارة الإعلانات الممولة' }) %>
<div class="container">
  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">🖼️ إدارة الإعلانات الممولة</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">رفع وإدارة البانرات التي تظهر في كاروسيل الصفحة الرئيسية</p>
    </div>
  </div>

  <!-- Upload Form -->
  <div class="pf-section" style="margin-bottom:24px;">
    <div class="pf-section-title"><span>➕</span><span>إضافة إعلان جديد</span></div>
    <form action="/admin/banners/upload" method="POST" enctype="multipart/form-data">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
        <div class="form-group" style="margin:0;">
          <label>صورة الإعلان <span style="color:var(--color-danger);">*</span></label>
          <input type="file" name="bannerImage" accept="image/*" required class="form-control">
          <p class="form-hint">صور بنسبة 16:9 أو 3:1 تبدو أفضل · حجم أقصى 5MB</p>
        </div>
        <div class="form-group" style="margin:0;">
          <label>عنوان الإعلان (اختياري)</label>
          <input type="text" name="title" placeholder="مثال: عروض رمضان 🎉" class="form-control">
        </div>
        <div class="form-group" style="margin:0;">
          <label>رابط عند الضغط (اختياري)</label>
          <input type="url" name="linkUrl" placeholder="https://..." class="form-control">
        </div>
        <div class="form-group" style="margin:0;">
          <label>ترتيب العرض</label>
          <input type="number" name="sortOrder" value="0" min="0" class="form-control">
          <p class="form-hint">الرقم الأصغر يظهر أولاً</p>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">رفع الإعلان</button>
    </form>
  </div>

  <!-- Existing Banners -->
  <div class="pf-section">
    <div class="pf-section-title"><span>📋</span><span>الإعلانات الحالية (<%= banners.length %>)</span></div>
    <% if (banners.length === 0) { %>
      <div style="text-align:center;padding:40px 20px;color:var(--color-muted);">
        <p style="font-size:2.5rem;margin-bottom:8px;">🖼️</p>
        <p>لا توجد إعلانات بعد. أضف أول إعلان من الأعلى.</p>
      </div>
    <% } else { %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
        <% banners.forEach(function(banner) { %>
          <div class="card" style="border-radius:14px;overflow:hidden;border:2px solid <%= banner.is_active ? 'var(--color-primary)' : 'var(--color-border)' %>;opacity:<%= banner.is_active ? 1 : 0.6 %>;">
            <div style="position:relative;">
              <img src="/public<%= banner.image_url %>" alt="<%= banner.title || 'إعلان' %>"
                   style="width:100%;height:140px;object-fit:cover;display:block;">
              <span style="position:absolute;top:8px;right:8px;background:<%= banner.is_active ? 'var(--color-success)' : '#888' %>;color:#fff;font-size:0.75rem;font-weight:700;padding:3px 9px;border-radius:20px;">
                <%= banner.is_active ? '✓ نشط' : '✗ متوقف' %>
              </span>
            </div>
            <div style="padding:12px 14px;">
              <% if (banner.title) { %>
                <p style="font-weight:700;margin:0 0 4px;"><%= banner.title %></p>
              <% } %>
              <% if (banner.link_url) { %>
                <p style="font-size:0.8rem;color:var(--color-muted);margin:0 0 10px;word-break:break-all;"><%= banner.link_url %></p>
              <% } %>
              <p style="font-size:0.8rem;color:var(--color-muted);margin:0 0 12px;">ترتيب: <%= banner.sort_order %></p>
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <form action="/admin/banners/<%= banner.id %>/toggle" method="POST" class="inline-form">
                  <button type="submit" class="btn btn-small btn-secondary">
                    <%= banner.is_active ? 'إيقاف' : 'تفعيل' %>
                  </button>
                </form>
                <form action="/admin/banners/<%= banner.id %>/delete" method="POST" class="inline-form"
                  onsubmit="return confirm('تأكيد حذف هذا الإعلان؟')">
                  <button type="submit" class="btn btn-small btn-danger">🗑 حذف</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
