<%- include('../../partials/header', { title: 'الطلبات الجاية' }) %>
<div class="container">

  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">الطلبات الجاية</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">تابع طلبات عملائك وصرف فيها</p>
    </div>
    <a href="/vendor/dashboard" class="btn btn-secondary btn-small">← لوحة التحكم</a>
  </div>

  <div class="tabs" style="margin-bottom:20px;overflow-x:auto;white-space:nowrap;">
    <a href="/vendor/orders" class="<%= currentStatus === 'all' ? 'tab active' : 'tab' %>">الكل</a>
    <a href="/vendor/orders?status=pending" class="<%= currentStatus === 'pending' ? 'tab active' : 'tab' %>">⏳ في الانتظار</a>
    <a href="/vendor/orders?status=confirmed" class="<%= currentStatus === 'confirmed' ? 'tab active' : 'tab' %>">✅ متأكد</a>
    <a href="/vendor/orders?status=preparing" class="<%= currentStatus === 'preparing' ? 'tab active' : 'tab' %>">🔧 بيتجهز</a>
    <a href="/vendor/orders?status=out_for_delivery" class="<%= currentStatus === 'out_for_delivery' ? 'tab active' : 'tab' %>">🚚 في الطريق</a>
    <a href="/vendor/orders?status=delivered" class="<%= currentStatus === 'delivered' ? 'tab active' : 'tab' %>">📦 وصل</a>
    <a href="/vendor/orders?status=cancelled" class="<%= currentStatus === 'cancelled' ? 'tab active' : 'tab' %>">❌ اتلغى</a>
  </div>

  <% if (orders.length === 0) { %>
    <div class="empty-state" style="padding:48px 0;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--color-muted)"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <p style="color:var(--color-muted);margin:0;">مفيش طلبات في التصنيف ده.</p>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <% orders.forEach(function(order) { %>
        <div class="vendor-order-card">
          <div class="vendor-order-card-header">
            <div>
              <span class="vendor-order-number">#<%= order.order_number %></span>
              <span class="vendor-order-amount"><%= order.total_amount.toFixed(0) %> ج.م</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
              <%
                var statusLabels = {
                  pending: 'في الانتظار',
                  confirmed: 'متأكد',
                  preparing: 'بيتجهز',
                  out_for_delivery: 'في الطريق',
                  delivered: 'وصل',
                  cancelled: 'اتلغى'
                };
              %>
              <span class="badge badge-<%= order.order_status === 'pending' ? 'warning' : order.order_status === 'cancelled' ? 'danger' : 'success' %>">
                <%= statusLabels[order.order_status] || order.order_status %>
              </span>
              <a href="/vendor/orders/<%= order.id %>" class="btn btn-small btn-secondary">التفاصيل</a>
            </div>
          </div>
          <div class="vendor-order-card-meta">
            <span style="color:var(--color-muted);font-size:0.83rem;">📅 <%= new Date(order.created_at).toLocaleDateString('ar-EG', {year:'numeric',month:'short',day:'numeric'}) %></span>
          </div>
          <% if (order.order_status === 'pending') { %>
            <div class="vendor-order-quick-actions">
              <form action="/vendor/orders/<%= order.id %>/status" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="confirmed">
                <button type="submit" class="btn btn-small btn-success">✅ اقبل الطلب</button>
              </form>
              <form action="/vendor/orders/<%= order.id %>/status" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="cancelled">
                <button type="submit" class="btn btn-small btn-danger">❌ ارفض الطلب</button>
              </form>
            </div>
          <% } else if (order.order_status === 'confirmed') { %>
            <div class="vendor-order-quick-actions">
              <form action="/vendor/orders/<%= order.id %>/status" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="preparing">
                <button type="submit" class="btn btn-small btn-primary">🔧 ابدأ التحضير</button>
              </form>
            </div>
          <% } else if (order.order_status === 'preparing') { %>
            <div class="vendor-order-quick-actions">
              <form action="/vendor/orders/<%= order.id %>/status" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="out_for_delivery">
                <button type="submit" class="btn btn-small btn-primary">🚚 بعتو للتوصيل</button>
              </form>
            </div>
          <% } else if (order.order_status === 'out_for_delivery') { %>
            <div class="vendor-order-quick-actions">
              <form action="/vendor/orders/<%= order.id %>/status" method="POST" style="display:inline;">
                <input type="hidden" name="status" value="delivered">
                <button type="submit" class="btn btn-small btn-success">📦 أكد التوصيل</button>
              </form>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../../partials/footer') %>
