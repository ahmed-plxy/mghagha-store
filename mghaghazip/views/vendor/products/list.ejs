<%- include('../../partials/header', { title: t('app.name') }) %>
<div class="container">
  <div class="page-header-row">
    <h1>منتجاتي</h1>
    <a href="/vendor/products/new" class="btn btn-primary">إضافة منتج جديد</a>
  </div>

  <% if (products.length === 0) { %>
    <p>لا توجد منتجات حتى الآن.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>المنتج</th>
          <th>الفئة</th>
          <th>السعر</th>
          <th>الكمية</th>
          <th>الحالة</th>
          <th>الإجراءات</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(product) { %>
          <tr>
            <td><%= product.name %></td>
            <td><%= product.category_name || '—' %></td>
            <td><%= product.price %> ج.م</td>
            <td><%= product.quantity %></td>
            <td>
              <span class="badge badge-<%= product.status === 'active' ? 'success' : 'muted' %>">
                <%= product.status === 'active' ? 'نشط' : 'متوقف' %>
              </span>
            </td>
            <td class="actions-cell">
              <a href="/vendor/products/<%= product.id %>/edit" class="btn btn-small btn-secondary">تعديل</a>
              <form action="/vendor/products/<%= product.id %>/toggle-status" method="POST" class="inline-form">
                <button type="submit" class="btn btn-small btn-secondary">
                  <%= product.status === 'active' ? 'إيقاف' : 'تفعيل' %>
                </button>
              </form>
              <form action="/vendor/products/<%= product.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('هل أنت متأكد من حذف هذا المنتج؟');">
                <button type="submit" class="btn btn-small btn-danger">حذف</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../../partials/footer') %>
