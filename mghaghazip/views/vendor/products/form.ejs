<%- include('../../partials/header', { title: t('app.name') }) %>

<div class="container pf-container">
  <div class="pf-header">
    <a href="/vendor/products" class="back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      العودة إلى منتجاتي
    </a>
    <h1 class="pf-title"><%= mode === 'create' ? 'إضافة منتج جديد' : 'تعديل المنتج' %></h1>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="pf-errors">
      <% errors.forEach(function(err) { %><p>⚠ <%= err %></p><% }) %>
    </div>
  <% } %>

  <form
    action="<%= mode === 'create' ? '/vendor/products/new' : '/vendor/products/' + product.id + '/edit' %>"
    method="POST"
    enctype="multipart/form-data"
    class="pf-form"
    id="productForm"
  >

    <!-- ===== STEP 1: PRODUCT NAME ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">١</span>
        <span>معلومات المنتج الأساسية</span>
      </div>
      <div class="form-group">
        <label for="name">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          اسم المنتج أو الإعلان
        </label>
        <input
          type="text"
          id="name"
          name="name"
          value="<%= (old && old.name) || (product && product.name) || '' %>"
          placeholder="مثال: موبايل سامسونج S23 للبيع"
          required
          class="pf-input"
        >
      </div>
    </div>

    <!-- ===== STEP 2: CATEGORY ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٢</span>
        <span>الفئة والتصنيف</span>
      </div>

      <input type="hidden" id="categoryId" name="categoryId" value="<%= (old && old.categoryId) || (product && product.category_id) || '' %>">

      <!-- Main Category Grid -->
      <div class="form-group">
        <label>الفئة الرئيسية</label>
        <div class="pf-cat-grid" id="mainCatGrid">
          <% mainCategories.forEach(function(cat) { %>
            <button type="button" class="pf-cat-chip" data-id="<%= cat.id %>" data-slug="<%= cat.slug %>">
              <span class="pf-cat-icon"><%= ({
                'vehicles':       '🚗',
                'mobiles':        '📱',
                'home-appliances':'❄️',
                'furniture':      '🛋️',
                'kitchen-tools':  '🍳',
                'computers':      '💻',
                'livestock':      '🐄',
                'crops':          '🌾',
                'real-estate':    '🏠',
                'professions':    '🔧',
                'clothing':       '👕',
                'accessories':    '💎',
                'marine-vehicles':'⛵',
                'sports-fitness': '🏋️'
              })[cat.slug] || '📦' %></span>
              <span class="pf-cat-label"><%= cat.name %></span>
            </button>
          <% }) %>
        </div>
      </div>

      <!-- Sub Category -->
      <div class="form-group" id="subCatGroup" style="display:none;">
        <label for="subCatSelect">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          الفئة الفرعية
        </label>
        <div class="pf-custom-select-wrap">
          <select id="subCatSelect" class="pf-custom-select">
            <option value="">— اختر الفئة الفرعية —</option>
          </select>
          <span class="pf-select-arrow">▾</span>
        </div>
      </div>
    </div>

    <!-- ===== STEP 3: DYNAMIC ATTRIBUTE FIELDS ===== -->
    <div class="pf-section" id="attrSection" style="display:none;">
      <div class="pf-section-title">
        <span class="pf-step">٣</span>
        <span>تفاصيل المنتج</span>
      </div>
      <div id="attrFields" class="pf-attr-grid"></div>
    </div>

    <!-- ===== STEP 4: DESCRIPTION ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step" id="descStep">٤</span>
        <span>الوصف والمواصفات</span>
      </div>
      <div class="form-group">
        <label for="description">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          وصف إضافي / المواصفات
        </label>
        <textarea id="description" name="description" rows="4" class="pf-input" placeholder="اكتب أي تفاصيل إضافية أو مواصفات تريد إضافتها..."><%= (old && old.description) || (product && product.description) || '' %></textarea>
      </div>
    </div>

    <!-- ===== STEP 5: PRICE & QUANTITY ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٥</span>
        <span>السعر والكمية ومصاريف الشحن</span>
      </div>
      <div class="pf-two-col">
        <div class="form-group">
          <label for="price">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            السعر (ج.م)
          </label>
          <input type="number" id="price" name="price" step="0.01" min="0"
            value="<%= (old && old.price) || (product && product.price) || '' %>"
            placeholder="0.00" required class="pf-input">
        </div>
        <div class="form-group">
          <label for="quantity">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            الكمية المتوفرة
          </label>
          <input type="number" id="quantity" name="quantity" step="1" min="0"
            value="<%= (old && old.quantity !== undefined) ? old.quantity : (product ? product.quantity : '') %>"
            placeholder="1" required class="pf-input">
        </div>
      </div>
      <div class="form-group">
        <label for="shippingCost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          مصاريف الشحن لهذا المنتج (ج.م)
        </label>
        <input type="number" id="shippingCost" name="shippingCost" step="0.01" min="0"
          value="<%= (old && old.shippingCost !== undefined && old.shippingCost !== '') ? old.shippingCost : (product && product.shipping_cost !== undefined && product.shipping_cost !== null ? product.shipping_cost : '') %>"
          placeholder="0.00" required class="pf-input" style="max-width:200px;">
        <p style="margin:6px 0 0;color:var(--color-muted);font-size:0.85rem;">كل منتج له مصاريف شحن مستقلة. اكتب <strong>0</strong> لو الشحن مجاني لهذا المنتج.</p>
      </div>
    </div>

    <!-- ===== STEP 6: IMAGES ===== -->
    <div class="pf-section">
      <div class="pf-section-title">
        <span class="pf-step">٦</span>
        <span>الصور</span>
      </div>
      <% if (images && images.length > 0) { %>
        <div class="form-group">
          <label>الصور الحالية</label>
          <div class="image-thumbs">
            <% images.forEach(function(img) { %>
              <img src="/uploads/<%= img.image_url %>" alt="صورة المنتج" class="thumb">
            <% }) %>
          </div>
        </div>
      <% } %>
      <div class="form-group">
        <label for="images">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          إضافة صور المنتج
        </label>
        <div class="pf-file-wrap">
          <label for="images" class="pf-file-label">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
            اختر الصور أو اسحبها هنا
          </label>
          <input type="file" id="images" name="images" accept="image/jpeg,image/png,image/webp" multiple class="pf-file-input">
          <p class="pf-file-hint">يمكن اختيار أكثر من صورة — JPEG, PNG, WebP</p>
        </div>
      </div>
    </div>

    <div class="pf-submit-row">
      <button type="submit" class="btn btn-primary pf-submit">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <%= mode === 'create' ? 'نشر المنتج' : 'حفظ التعديلات' %>
      </button>
      <a href="/vendor/products" class="btn btn-secondary">إلغاء</a>
    </div>
  </form>
</div>

