  // ─── Saved values for edit mode ─────────────────────────────────────────────
  const savedAttrs    = <%- JSON.stringify(locals.productAttrs || {}) %>;
  const savedCatId    = parseInt('<%= (old && old.categoryId) || (product && product.category_id) || "" %>') || null;
  const savedMainId   = findMainForSub(savedCatId);

  // ─── DOM refs ───────────────────────────────────────────────────────────────
  const mainGrid      = document.getElementById('mainCatGrid');
  const subGroup      = document.getElementById('subCatGroup');
  const subSelect     = document.getElementById('subCatSelect');
  const attrSection   = document.getElementById('attrSection');
  const attrFields    = document.getElementById('attrFields');
  const hiddenCatId   = document.getElementById('categoryId');

  // ─── Helpers ────────────────────────────────────────────────────────────────
  function findMainForSub(subId) {
    if (!subId) return null;
    for (const [mainId, subs] of Object.entries(SUBS_MAP)) {
      if (subs.some(s => s.id === subId)) return parseInt(mainId);
    }
    return null;
  }

  function selectMain(mainId, mainSlug) {
    document.querySelectorAll('.pf-cat-chip').forEach(el => el.classList.remove('active'));
    const chip = mainGrid.querySelector(`[data-id="${mainId}"]`);
    if (chip) chip.classList.add('active');

    const subs = SUBS_MAP[mainId] || [];
    subSelect.innerHTML = '<option value="">— اختر الفئة الفرعية —</option>';
    subs.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.id;
      opt.textContent = s.name;
      subSelect.appendChild(opt);
    });
    subGroup.style.display = subs.length ? 'block' : 'none';
    if (window.csdRefresh) window.csdRefresh(subSelect);

    clearAttrFields();
  }

  function selectSub(subId) {
    hiddenCatId.value = subId || '';
    if (!subId) { clearAttrFields(); return; }
    const slug = Array.from(subSelect.options).find(o => o.value == subId)?.dataset?.slug;
    const subSlug = (function() {
      for (const [, subs] of Object.entries(SUBS_MAP)) {
        const found = subs.find(s => s.id == subId);
        if (found) return found.slug;
      }
      return null;
    })();
    renderAttrFields(subSlug);
  }

  function clearAttrFields() {
    attrSection.style.display = 'none';
    attrFields.innerHTML = '';
  }

  function renderAttrFields(subSlug) {
    const config = ATTR_CONFIG[subSlug];
    if (!config || config.length === 0) { clearAttrFields(); return; }

    attrFields.innerHTML = '';
    config.forEach(function(field) {
      const saved = savedAttrs[field.name] || '';
      const div = document.createElement('div');
      div.className = 'pf-attr-field';

      let inputHtml = '';
      if (field.type === 'select') {
        const opts = field.options.map(o =>
          `<option value="${o}" ${saved === o ? 'selected' : ''}>${o}</option>`
        ).join('');
        inputHtml = `<select name="attr_${field.name}" class="pf-input" data-csd><option value="">— اختر —</option>${opts}</select>`;
      } else {
        const extra = field.min !== undefined ? `min="${field.min}"` : '';
        const extra2 = field.max !== undefined ? `max="${field.max}"` : '';
        const ph = field.placeholder ? `placeholder="${field.placeholder}"` : '';
        inputHtml = `<input type="${field.type}" name="attr_${field.name}" value="${saved}" class="pf-input" ${extra} ${extra2} ${ph}>`;
      }

      div.innerHTML = `
        <label>
          <span class="pf-attr-icon">${field.icon}</span>
          ${field.label}
        </label>
        ${inputHtml}
      `;
      attrFields.appendChild(div);
    });

    attrSection.style.display = 'block';
  }

  // ─── Event listeners ────────────────────────────────────────────────────────
  mainGrid.addEventListener('click', function(e) {
    const chip = e.target.closest('.pf-cat-chip');
    if (!chip) return;
    selectMain(parseInt(chip.dataset.id), chip.dataset.slug);
    hiddenCatId.value = '';
    clearAttrFields();
  });

  subSelect.addEventListener('change', function() {
    selectSub(this.value);
  });

  // ─── Restore saved state (edit mode) ────────────────────────────────────────
  if (savedMainId) {
    selectMain(savedMainId, '');
    if (savedCatId) {
      subSelect.value = savedCatId;
      selectSub(savedCatId);
    }
  }
})();
