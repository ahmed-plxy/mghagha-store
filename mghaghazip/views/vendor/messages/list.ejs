<%- include('../../partials/header', { title: 'الرسائل' }) %>
<div class="container">

  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">رسائل العملاء</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">محادثاتك مع عملاء متجرك (<%= conversations.length %>)</p>
    </div>
  </div>

  <% if (conversations.length === 0) { %>
    <div class="chat-empty-list">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="56" height="56"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      <p style="margin:0;font-size:1rem;font-weight:600;">لا توجد رسائل بعد</p>
      <p style="margin:0;font-size:0.88rem;">ستظهر هنا رسائل العملاء عند تواصلهم معك</p>
    </div>
  <% } else { %>
    <div class="chat-list">
      <% conversations.forEach(function(c) { %>
        <a href="/vendor/messages/<%= c.id %>" class="chat-list-item">
          <div class="chat-list-avatar" style="font-size:1.1rem;">👤</div>
          <div class="chat-list-info">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              <p class="chat-list-name" style="margin:0;"><%= c.customer_name %></p>
              <% if (c.customer_phone && !c.customer_phone.startsWith('google_')) { %>
                <span class="chat-list-phone">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 12 19.79 19.79 0 011.58 3.45 2 2 0 013.55 1.27h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 8.82a16 16 0 006.27 6.27l1.62-1.62a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  <%= c.customer_phone %>
                </span>
              <% } %>
            </div>
            <% if (c.last_body) { %>
              <p class="chat-list-preview">
                <%= c.last_sender_id === currentUser.id ? 'أنت: ' : '' %><%= c.last_body.length > 50 ? c.last_body.substring(0, 50) + '...' : c.last_body %>
              </p>
            <% } else { %>
              <p class="chat-list-preview">لا توجد رسائل بعد</p>
            <% } %>
            <div class="chat-list-meta">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <%= new Date(c.last_message_at + 'Z').toLocaleString('ar-EG', {timeZone:'Africa/Cairo', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'}) %>
            </div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="chat-list-chevron"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
      <% }) %>
    </div>
  <% } %>

</div>
<%- include('../../partials/footer') %>
