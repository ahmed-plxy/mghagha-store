<%- include('../partials/header', { title: 'تفعيل الإيميل' }) %>

<div class="auth-page">
  <div class="ve-card">

    <div class="ve-header">
      <div class="ve-header-icon">📬</div>
      <h1 class="ve-title">تحقق من إيميلك</h1>
      <p class="ve-subtitle">
        بعتنالك كود مكوّن من 6 أرقام على<br>
        <strong dir="ltr"><%= email %></strong>
      </p>
    </div>

    <% if (locals.flashMessages) { %>
      <% if (flashMessages.type === 'success') { %>
        <div class="ve-flash ve-flash--success">✓ <%= flashMessages.text %></div>
      <% } else if (flashMessages.type === 'info') { %>
        <div class="ve-flash ve-flash--info">ℹ <%= flashMessages.text %></div>
      <% } else if (flashMessages.type === 'error') { %>
        <div class="ve-flash ve-flash--error">⚠ <%= flashMessages.text %></div>
      <% } %>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="ve-flash ve-flash--error">
        <% errors.forEach(function(e){ %><p>⚠ <%= e %></p><% }) %>
      </div>
    <% } %>

    <form action="/auth/verify-email" method="POST" class="ve-form" id="veForm" onsubmit="prepareCode()">
      <p class="ve-code-label">أدخل الكود هنا</p>
      <div class="ve-boxes" id="veBoxes">
        <input class="ve-box" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code" autofocus>
        <input class="ve-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="ve-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="ve-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="ve-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
        <input class="ve-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
      </div>
      <input type="hidden" name="code" id="codeHidden">
      <button type="submit" class="ve-submit" id="veSubmit" disabled>تفعيل الحساب</button>
    </form>

    <div class="ve-resend-wrap">
      <p class="ve-resend-hint" id="resendHint">يمكنك طلب كود جديد بعد <span id="countdown">60</span> ثانية</p>
      <form action="/auth/resend-verification" method="POST" id="resendForm">
        <button type="submit" class="ve-resend-btn" id="resendBtn" disabled>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.1"/></svg>
          إرسال كود جديد
        </button>
      </form>
    </div>

    <div class="ve-divider"></div>

    <div class="ve-bottom">
      <form action="/auth/logout" method="POST" style="display:inline;">
        <button type="submit" class="ve-logout-btn">تسجيل الخروج والعودة</button>
      </form>
    </div>

  </div>
</div>

<style>
.auth-page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px 16px 60px; background:var(--color-bg); }
.ve-card { width:100%; max-width:420px; background:var(--color-card); border-radius:20px; box-shadow:var(--shadow-card); overflow:hidden; }

.ve-header { background:linear-gradient(135deg, var(--color-primary), var(--color-primary-dark)); padding:30px 24px 26px; text-align:center; }
.ve-header-icon { font-size:2.5rem; margin-bottom:10px; }
.ve-title { color:#fff; font-size:1.25rem; font-weight:700; margin:0 0 8px; }
.ve-subtitle { color:rgba(255,255,255,0.75); font-size:.88rem; line-height:1.6; margin:0; }
.ve-subtitle strong { color:#fff; }

.ve-flash { margin:16px 20px 0; padding:11px 14px; border-radius:10px; font-size:.88rem; line-height:1.5; }
.ve-flash--success { background:var(--color-primary-tint); border:1px solid var(--color-primary); color:var(--color-primary-dark); }
.ve-flash--info    { background:var(--color-primary-tint); border:1px solid var(--color-primary); color:var(--color-primary-dark); }
.ve-flash--error   { background:var(--color-danger-tint); border:1px solid var(--color-danger); color:var(--color-danger); }
.ve-flash p { margin:0; }

.ve-form { padding:22px 20px 8px; display:flex; flex-direction:column; align-items:center; gap:16px; }
.ve-code-label { font-size:.85rem; font-weight:600; color:var(--color-text); margin:0; align-self:flex-start; }

.ve-boxes { display:flex; gap:10px; justify-content:center; direction:ltr; }
.ve-box {
  width:46px; height:56px; text-align:center; font-size:1.5rem; font-weight:700;
  border:2px solid var(--color-border); border-radius:12px;
  background:var(--color-bg); color:var(--color-text);
  outline:none; transition:border-color .15s, box-shadow .15s;
  font-family:monospace; caret-color:transparent;
}
.ve-box:focus { border-color:var(--color-primary); box-shadow:0 0 0 3px var(--color-primary-tint); }
.ve-box.filled { border-color:var(--color-primary); background:var(--color-primary-tint); }
@media (max-width:360px) { .ve-box { width:40px; height:50px; font-size:1.3rem; } .ve-boxes { gap:7px; } }

.ve-submit { width:100%; padding:13px; background:var(--color-primary); color:#fff; border:none; border-radius:12px; font-size:1rem; font-weight:700; cursor:pointer; transition:background .15s, opacity .15s; font-family:inherit; }
.ve-submit:hover:not(:disabled) { background:var(--color-primary-dark); }
.ve-submit:disabled { opacity:.4; cursor:not-allowed; }

.ve-resend-wrap { padding:4px 20px 16px; text-align:center; }
.ve-resend-hint { font-size:.82rem; color:var(--color-muted); margin:0 0 8px; }
.ve-resend-btn { display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:none; border:1.5px solid var(--color-border); border-radius:10px; font-size:.86rem; color:var(--color-text); cursor:pointer; transition:background .15s, border-color .15s; font-family:inherit; font-weight:600; }
.ve-resend-btn:hover:not(:disabled) { background:var(--color-bg-alt); border-color:var(--color-primary); }
.ve-resend-btn:disabled { opacity:.4; cursor:not-allowed; }

.ve-divider { border-top:1px solid var(--color-border); margin:0 20px; }
.ve-bottom { padding:14px 20px 20px; text-align:center; }
.ve-logout-btn { background:none; border:none; font-size:.83rem; color:var(--color-muted); cursor:pointer; text-decoration:underline; font-family:inherit; }
.ve-logout-btn:hover { color:var(--color-text); }
</style>

<script>
(function () {
  var boxes   = Array.from(document.querySelectorAll('.ve-box'));
  var hidden  = document.getElementById('codeHidden');
  var submitBtn = document.getElementById('veSubmit');

  function updateHidden() {
    var val = boxes.map(function(b){ return b.value; }).join('');
    hidden.value = val;
    submitBtn.disabled = val.length < 6;
    boxes.forEach(function(b){
      b.classList.toggle('filled', b.value !== '');
    });
  }

  boxes.forEach(function (box, i) {
    box.addEventListener('input', function () {
      var v = this.value.replace(/\D/g, '').slice(-1);
      this.value = v;
      if (v && i < boxes.length - 1) boxes[i + 1].focus();
      updateHidden();
    });
    box.addEventListener('keydown', function (e) {
      if (e.key === 'Backspace' && !this.value && i > 0) {
        boxes[i - 1].value = '';
        boxes[i - 1].focus();
        updateHidden();
      }
      if (e.key === 'ArrowRight' && i > 0) boxes[i - 1].focus();
      if (e.key === 'ArrowLeft'  && i < boxes.length - 1) boxes[i + 1].focus();
    });
    box.addEventListener('paste', function (e) {
      e.preventDefault();
      var txt = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
      txt.split('').slice(0, boxes.length).forEach(function(ch, j){
        if (boxes[i + j]) boxes[i + j].value = ch;
      });
      boxes[Math.min(i + txt.length, boxes.length - 1)].focus();
      updateHidden();
    });
  });
})();

function prepareCode() { /* hidden already populated */ }

(function () {
  var btn    = document.getElementById('resendBtn');
  var hint   = document.getElementById('resendHint');
  var cdSpan = document.getElementById('countdown');
  var secs   = 60;
  var timer  = setInterval(function () {
    secs--;
    cdSpan.textContent = secs;
    if (secs <= 0) {
      clearInterval(timer);
      btn.disabled = false;
      hint.textContent = 'لم يصلك الكود؟ يمكنك إعادة الإرسال الآن.';
    }
  }, 1000);
})();
</script>

<%- include('../partials/footer') %>
