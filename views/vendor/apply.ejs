<%- include('../partials/header', { title: t('app.name') }) %>
<div class="container pf-container">
  <div class="pf-header">
    <a href="/" class="back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      العودة للرئيسية
    </a>
    <h1 class="pf-title">طلب انضمام كبائع</h1>
  </div>

  <% if (pendingApplication) { %>
    <div class="info-card">
      <p>لديك طلب قيد المراجعة حاليًا لمتجر "<strong><%= pendingApplication.store_name %></strong>".</p>
      <p>سيتم إشعارك بعد مراجعة الإدارة للطلب.</p>
    </div>
  <% } else { %>

    <% if (errors && errors.length > 0) { %>
      <div class="pf-errors">
        <% errors.forEach(function(err) { %><p>⚠ <%= err %></p><% }) %>
      </div>
    <% } %>

    <form action="/vendor/apply" method="POST" enctype="multipart/form-data" class="pf-form">

      <div class="pf-section">
        <div class="pf-section-title">
          <span class="pf-step">١</span>
          <span>بيانات المتجر</span>
        </div>
        <div class="form-group">
          <label for="storeName">اسم المتجر</label>
          <input type="text" id="storeName" name="storeName" value="<%= old.storeName || '' %>" required class="pf-input" placeholder="مثال: متجر الهواري">
        </div>
        <div class="form-group">
          <label for="phone">رقم هاتف التواصل</label>
          <input type="text" id="phone" name="phone" value="<%= old.phone || '' %>" required class="pf-input" placeholder="01XXXXXXXXX">
        </div>
      </div>

      <div class="pf-section">
        <div class="pf-section-title">
          <span class="pf-step">٢</span>
          <span>الموقع الجغرافي</span>
        </div>

        <div class="form-group">
          <label>المنطقة / القرية</label>
          <input type="hidden" id="areaId" name="areaId" value="<%= old.areaId || '' %>" required>
          <div class="pf-search-select" id="areaSelectWrap">
            <button type="button" class="pf-search-select-trigger" id="areaTrigger">
              <span id="areaTriggerText" class="<%= old.areaId ? '' : 'trigger-placeholder' %>">
                <%= old.areaId ? (areas.find(a => a.id == old.areaId) || {}).name || 'اختر المنطقة' : 'اختر المنطقة أو اكتب للبحث' %>
              </span>
              <span>▾</span>
            </button>
            <div class="pf-search-select-list" id="areaList">
              <div style="padding:8px 12px; border-bottom:1px solid var(--color-border);">
                <input type="text" class="pf-search-select-input" id="areaSearch" placeholder="🔍 ابحث عن منطقتك..." autocomplete="off" style="border-radius:6px; border:1px solid var(--color-border); padding:8px 10px; width:100%; box-sizing:border-box;">
              </div>
              <div id="areaOptions">
                <% areas.forEach(function(area) { %>
                  <div class="pf-search-select-option<%= (old.areaId && Number(old.areaId) === area.id) ? ' selected' : '' %>"
                       data-id="<%= area.id %>"
                       data-name="<%= area.name %>">
                    <%= area.name %>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label for="fullAddress">العنوان بالتفصيل</label>
          <textarea id="fullAddress" name="fullAddress" rows="3" required class="pf-input" placeholder="مثال: شارع الجمهورية، أمام المسجد الكبير"><%= old.fullAddress || '' %></textarea>
        </div>
      </div>

      <div class="pf-section">
        <div class="pf-section-title">
          <span class="pf-step">٣</span>
          <span>صور البطاقة الشخصية</span>
        </div>
        <p style="color:var(--color-muted);font-size:0.88rem;margin-bottom:16px;">تُستخدم للتحقق من هويتك فقط ولن تُشارَك مع أحد.</p>
        <div class="pf-two-col">
          <div class="form-group">
            <label for="idCardFront">الوجه الأمامي</label>
            <div class="pf-file-wrap">
              <label for="idCardFront" class="pf-file-label">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="14" y2="13"/></svg>
                اختر صورة
              </label>
              <input type="file" id="idCardFront" name="idCardFront" accept="image/jpeg,image/png,image/webp" required class="pf-file-input">
            </div>
          </div>
          <div class="form-group">
            <label for="idCardBack">الوجه الخلفي</label>
            <div class="pf-file-wrap">
              <label for="idCardBack" class="pf-file-label">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="14" y2="13"/></svg>
                اختر صورة
              </label>
              <input type="file" id="idCardBack" name="idCardBack" accept="image/jpeg,image/png,image/webp" required class="pf-file-input">
            </div>
          </div>
        </div>
      </div>

      <div class="pf-submit-row">
        <button type="submit" class="btn btn-primary pf-submit">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          إرسال الطلب
        </button>
        <a href="/" class="btn btn-secondary">إلغاء</a>
      </div>

    </form>
  <% } %>
</div>

<script>
(function() {
  const trigger   = document.getElementById('areaTrigger');
  if (!trigger) return;
  const trigText  = document.getElementById('areaTriggerText');
  const list      = document.getElementById('areaList');
  const searchEl  = document.getElementById('areaSearch');
  const hiddenEl  = document.getElementById('areaId');
  const options   = Array.from(document.querySelectorAll('.pf-search-select-option'));

  function openList() {
    list.classList.add('open');
    trigger.classList.add('open');
    searchEl.focus();
  }
  function closeList() {
    list.classList.remove('open');
    trigger.classList.remove('open');
  }

  trigger.addEventListener('click', function(e) {
    e.stopPropagation();
    list.classList.contains('open') ? closeList() : openList();
  });

  document.addEventListener('click', function() { closeList(); });
  list.addEventListener('click', function(e) { e.stopPropagation(); });

  searchEl.addEventListener('input', function() {
    const q = this.value.trim().toLowerCase();
    options.forEach(function(opt) {
      const name = opt.dataset.name.toLowerCase();
      opt.style.display = (!q || name.includes(q)) ? '' : 'none';
    });
  });

  options.forEach(function(opt) {
    opt.addEventListener('click', function() {
      options.forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      hiddenEl.value = opt.dataset.id;
      trigText.textContent = opt.dataset.name;
      trigText.classList.remove('trigger-placeholder');
      trigger.style.borderColor = '';
      closeList();
      searchEl.value = '';
      options.forEach(o => o.style.display = '');
    });
  });

  // File name display
  document.querySelectorAll('.pf-file-input').forEach(function(input) {
    input.addEventListener('change', function() {
      const label = input.previousElementSibling;
      if (input.files && input.files[0]) {
        const span = label.querySelector('span') || label;
        if (label.tagName === 'LABEL') {
          const nameSpan = label.querySelector('.file-chosen-name');
          if (!nameSpan) {
            const s = document.createElement('span');
            s.className = 'file-chosen-name';
            s.style.cssText = 'font-size:0.8rem;color:var(--color-muted);display:block;margin-top:4px;';
            s.textContent = '✓ ' + input.files[0].name;
            label.appendChild(s);
          } else {
            nameSpan.textContent = '✓ ' + input.files[0].name;
          }
        }
      }
    });
  });

  // Form validation before submit
  document.querySelector('form').addEventListener('submit', function(e) {
    if (!hiddenEl.value) {
      e.preventDefault();
      trigger.style.borderColor = 'var(--color-danger)';
      trigger.scrollIntoView({ behavior: 'smooth', block: 'center' });
      openList();
    }
  });
})();
</script>

<%- include('../partials/footer') %>
