}
.privacy-right-icon { font-size: 1.4rem; }
.privacy-right-card strong { font-size: .9rem; color: var(--color-text); }
.privacy-right-card p { margin: 0; font-size: .82rem; color: var(--color-muted); line-height: 1.5; }
