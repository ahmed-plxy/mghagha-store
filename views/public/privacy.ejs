.privacy-highlight-box {
  background: rgba(37,99,235,.06);
  border: 1.5px solid rgba(37,99,235,.2);
  border-radius: 12px;
  padding: 16px 18px;
  display: flex;
  gap: 14px;
  align-items: flex-start;
  color: #1d4ed8;
}
[data-theme="dark"] .privacy-highlight-box { background: rgba(37,99,235,.12); }
.privacy-highlight-box svg { flex-shrink: 0; margin-top: 3px; }
.privacy-highlight-box p { margin: 0 0 8px; font-size: .88rem; line-height: 1.65; color: var(--color-text); }
.privacy-highlight-box p:last-child { margin-bottom: 0; }

.privacy-table {
  width: 100%;
  border-collapse: collapse;
  font-size: .86rem;
  margin-top: 12px;
}
.privacy-table th {
  background: var(--color-bg-alt);
  color: var(--color-text);
  font-weight: 700;
