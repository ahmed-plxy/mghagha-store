  color: var(--color-text);
  line-height: 1.55;
}
.privacy-table tr:last-child td { border-bottom: none; }
.privacy-table tr:hover td { background: var(--color-bg-alt); }

.privacy-rights-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@media (max-width: 520px) { .privacy-rights-grid { grid-template-columns: 1fr; } }
.privacy-right-card {
  background: var(--color-bg-alt);
