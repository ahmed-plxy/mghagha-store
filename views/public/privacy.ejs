  right: 0;
  color: var(--color-primary);
  font-weight: 700;
}

.privacy-data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@media (max-width: 520px) { .privacy-data-grid { grid-template-columns: 1fr; } }
.privacy-data-card {
  display: flex;
  gap: 12px;
  background: var(--color-bg-alt);
  border: 1.5px solid var(--color-border);
  border-radius: 12px;
  padding: 14px;
  align-items: flex-start;
}
.privacy-data-icon { font-size: 1.4rem; flex-shrink: 0; }
