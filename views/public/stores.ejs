<%- include('../partials/header', { title: 'المتاجر' }) %>

<div class="container" style="max-width:960px;padding-bottom:48px;">

  <div style="margin:20px 0 18px;">
    <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 4px;">🏪 المتاجر في مغاغة</h1>
    <p style="color:var(--color-muted);margin:0;font-size:.9rem;">تصفح محلات الحي وتواصل مع أصحابها مباشرة</p>
  </div>

  <form action="/stores" method="GET" class="stores-filter-bar">
    <div class="stores-filter-search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="flex-shrink:0;color:var(--color-muted)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" name="search" value="<%= filters.search %>" placeholder="ابحث باسم المتجر..." class="stores-filter-input">
    </div>
    <div class="stores-filter-select-wrap">
      <select name="areaId" class="auth-input stores-area-select">
        <option value="">📍 كل المناطق</option>
        <% areas.forEach(function(area) { %>
          <option value="<%= area.id %>" <%= Number(filters.areaId) === area.id ? 'selected' : '' %>><%= area.name %></option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn btn-primary stores-filter-btn">تصفية</button>
  </form>

  <% if (stores.length === 0) { %>
    <div style="text-align:center;padding:48px 20px;color:var(--color-muted);">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48" style="margin-bottom:14px;opacity:.4"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <p style="font-weight:600;margin:0 0 6px;">لا توجد متاجر مطابقة لبحثك</p>
      <a href="/stores" style="color:var(--color-primary);font-size:.9rem;">عرض كل المتاجر</a>
    </div>
  <% } else { %>
    <div class="grid">
      <% stores.forEach(function(store) { %>
        <a href="/stores/<%= store.store_slug %>" class="card-link">
          <% if (store.cover_image) { %>
            <img src="/uploads/<%= store.cover_image %>" alt="<%= store.store_name %>" class="card-image">
          <% } else { %>
            <div class="card-image-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            </div>
          <% } %>
          <div class="card-body">
            <h3 class="card-title"><%= store.store_name %></h3>
            <p class="card-meta">📍 <%= store.area_name || 'مغاغة' %></p>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>

<style>
.stores-filter-bar {
  display: flex;
  gap: 10px;
  align-items: flex-end;
  margin-bottom: 24px;
  flex-wrap: wrap;
}
.stores-filter-search {
  flex: 1 1 220px;
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--color-card);
  border: 1.5px solid var(--color-border);
  border-radius: 10px;
  padding: 0 14px;
  transition: border-color .18s;
}
.stores-filter-search:focus-within {
  border-color: var(--color-primary);
}
.stores-filter-input {
  flex: 1;
  border: none;
  background: none;
  padding: 11px 0;
  font-family: inherit;
  font-size: .95rem;
  color: var(--color-text);
  outline: none;
}
.stores-filter-input::placeholder { color: var(--color-muted); }
.stores-filter-select-wrap {
  flex: 1 1 180px;
  min-width: 160px;
}
.stores-area-select {
  width: 100%;
}
.stores-filter-btn {
  flex-shrink: 0;
  padding: 11px 22px;
  white-space: nowrap;
}
</style>

<%- include('../partials/footer') %>
