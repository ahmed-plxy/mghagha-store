<script>
(function() {
  var tabs = document.querySelectorAll('.legal-tab');
  var sections = document.querySelectorAll('.legal-section');

  function activate(tabId) {
    tabs.forEach(function(t) { t.classList.toggle('active', t.dataset.tab === tabId); });
    sections.forEach(function(s) { s.classList.toggle('legal-section--hidden', s.dataset.section !== tabId); });
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      activate(tab.dataset.tab);
      history.replaceState(null, '', '#' + tab.dataset.tab);
    });
  });

  var hash = window.location.hash.replace('#', '');
  if (hash && document.getElementById(hash)) activate(hash);
})();
</script>

