<%- include('../partials/header', { title: 'تتبع الطلب' }) %>
<div class="container">
  <h1>تتبع الطلب</h1>
  <h2><%= order.store_name %> — <%= order.order_number %></h2>

  <%
    const steps = ['pending','confirmed','preparing','out_for_delivery','delivered'];
    const currentIndex = steps.indexOf(order.order_status);
  %>

  <% if (order.order_status === 'cancelled') { %>
    <div class="status-timeline">
      <span class="status-step cancelled">تم إلغاء الطلب</span>
    </div>
  <% } else { %>
    <div class="status-timeline">
      <% steps.forEach(function(step, index) { %>
        <span class="status-step <%= index <= currentIndex ? 'completed' : '' %>"><%= orderStatusLabel(step) %></span>
      <% }) %>
    </div>
  <% } %>

  <div class="info-card">
    <p><strong>عنوان التوصيل:</strong> <%= order.customer_address %></p>
    <p><strong>رقم هاتف التواصل:</strong> <%= order.customer_phone %></p>
    <p><strong>طريقة الدفع:</strong> الدفع عند الاستلام</p>
    <p><strong>حالة الدفع:</strong> <%= order.payment_status === 'paid' ? 'مدفوع' : 'قيد الانتظار' %></p>
  </div>

  <table class="data-table">
    <thead>
      <tr><th>المنتج</th><th>الكمية</th><th>السعر</th><th>الإجمالي</th></tr>
    </thead>
    <tbody>
      <% items.forEach(function(item) { %>
        <tr>
          <td><%= item.product_name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.unit_price.toFixed(2) %> ج.م</td>
          <td><%= item.subtotal.toFixed(2) %> ج.م</td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <p style="text-align:left; font-weight:700; margin-top:10px;">الإجمالي: <%= order.total_amount.toFixed(2) %> ج.م</p>

  <% items.forEach(function(item) { %>
    <% if (item.canReview) { %>
      <div class="review-form-inline">
        <strong>قيّم منتج: <%= item.product_name %></strong>
        <form action="/customer/reviews" method="POST" style="margin-top:8px;">
          <input type="hidden" name="productId" value="<%= item.product_id %>">
          <input type="hidden" name="redirectTo" value="/customer/orders/<%= order.id %>">
          <div class="form-group">
            <label for="rating-<%= item.product_id %>">التقييم</label>
            <select id="rating-<%= item.product_id %>" name="rating" required>
              <option value="5">★★★★★ (ممتاز)</option>
              <option value="4">★★★★☆ (جيد جدًا)</option>
              <option value="3">★★★☆☆ (جيد)</option>
              <option value="2">★★☆☆☆ (مقبول)</option>
              <option value="1">★☆☆☆☆ (ضعيف)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="comment-<%= item.product_id %>">تعليقك (اختياري)</label>
            <textarea id="comment-<%= item.product_id %>" name="comment" rows="2"></textarea>
          </div>
          <button type="submit" class="btn btn-small btn-primary">إرسال التقييم</button>
        </form>
      </div>
    <% } else if (item.existingReview) { %>
      <div class="review-form-inline">
        <strong>تقييمك لمنتج <%= item.product_name %>:</strong>
        <p class="review-stars"><%= '★'.repeat(item.existingReview.rating) %><%= '☆'.repeat(5 - item.existingReview.rating) %></p>
        <% if (item.existingReview.comment) { %><p><%= item.existingReview.comment %></p><% } %>
      </div>
    <% } %>
  <% }) %>

  <a href="/customer/orders" class="btn btn-secondary" style="margin-top:16px; display:inline-block;">رجوع إلى طلباتي</a>
</div>
<%- include('../partials/footer') %>
