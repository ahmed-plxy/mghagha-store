<%- include('../partials/header', { title: 'المفضلة' }) %>
<div class="container">
  <h1>المفضلة</h1>

  <% if (items.length === 0) { %>
    <p>لا توجد منتجات في المفضلة حتى الآن. <a href="/products">تصفح المنتجات</a></p>
  <% } else { %>
    <div class="grid">
      <% items.forEach(function(item) { %>
        <div class="card-link" style="cursor:default;">
          <a href="/stores/<%= item.store_slug %>/products/<%= item.slug %>" style="text-decoration:none; color:inherit;">
            <% if (item.image_url) { %>
              <img src="/uploads/<%= item.image_url %>" alt="<%= item.name %>" class="card-image">
            <% } else { %>
              <div class="card-image-placeholder">لا توجد صورة</div>
            <% } %>
            <div class="card-body">
              <h3 class="card-title"><%= item.name %></h3>
              <p class="card-meta"><%= item.store_name %></p>
              <p class="card-price"><%= item.price.toFixed(2) %> ج.م</p>
            </div>
          </a>
          <div style="padding: 0 16px 16px;">
            <form action="/customer/wishlist/toggle" method="POST">
              <input type="hidden" name="productId" value="<%= item.id %>">
              <input type="hidden" name="redirectTo" value="/customer/wishlist">
              <button type="submit" class="btn btn-small btn-danger">إزالة من المفضلة</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
