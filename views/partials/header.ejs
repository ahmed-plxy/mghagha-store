<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<script>
  (function(){
    var t = localStorage.getItem('mghagha-theme');
    if (t === 'dark') document.documentElement.setAttribute('data-theme','dark');
  })();
</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : t('app.name') %> | <%= t('app.name') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/fonts.css">
  <link rel="stylesheet" href="/public/css/rtl.css">
  <link rel="stylesheet" href="/public/css/dashboard.css">
  <link rel="stylesheet" href="/public/css/public.css">
  <link rel="stylesheet" href="/public/css/chat.css">
  <link rel="stylesheet" href="/public/css/nav.css">
  <link rel="stylesheet" href="/public/css/pages.css">

  <!-- OneSignal Web Push -->
  <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
  <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(async function(OneSignal) {
      await OneSignal.init({
        appId: "<%= typeof oneSignalAppId !== 'undefined' ? oneSignalAppId : '' %>",
        serviceWorkerPath: "/OneSignalSDKWorker.js",
        notifyButton: { enable: false },
        allowLocalhostAsSecureOrigin: true,
      });
    });
  </script>
</head>
<body>
  <header class="site-header">
    <nav class="navbar">
      <a href="/" class="brand"><%= t('app.name') %></a>

      <%# Desktop nav links (hidden on mobile via nav.css) %>
      <ul class="nav-links">
        <li><a href="/"><%= t('nav.home') %></a></li>
        <li><a href="/stores"><%= t('nav.stores') %></a></li>
        <li><a href="/products">المنتجات</a></li>
        <% if (currentUser) { %>
          <% if (currentUser.role === 'customer') { %>
            <li><a href="/customer/cart"><%= t('nav.cart') %></a></li>
            <li><a href="/customer/orders">طلباتي</a></li>
            <li><a href="/customer/wishlist">المفضلة</a></li>
            <li><a href="/customer/messages">الرسائل<% if (unreadMessageCount > 0) { %> (<%= unreadMessageCount %>)<% } %></a></li>
            <li><a href="/customer/dashboard">حسابي</a></li>
          <% } else if (currentUser.role === 'vendor') { %>
            <li><a href="/vendor/dashboard">لوحة البائع</a></li>
            <li><a href="/vendor/products">منتجاتي</a></li>
            <li><a href="/vendor/orders">الطلبات</a></li>
            <li><a href="/vendor/messages">الرسائل<% if (unreadMessageCount > 0) { %> (<%= unreadMessageCount %>)<% } %></a></li>
          <% } else if (currentUser.role === 'admin') { %>
            <li><a href="/admin/dashboard">لوحة الإدارة</a></li>
            <li><a href="/admin/stores">المتاجر</a></li>
            <li><a href="/admin/orders">الطلبات</a></li>
          <% } %>
          <li><a href="/notifications">🔔<% if (unreadNotificationCount > 0) { %> (<%= unreadNotificationCount %>)<% } %></a></li>
          <li>
            <form action="/auth/logout" method="POST" class="inline-form">
              <button type="submit" class="link-button"><%= t('nav.logout') %></button>
            </form>
          </li>
        <% } else { %>
          <li><a href="/auth/login"><%= t('nav.login') %></a></li>
          <li><a href="/auth/register"><%= t('nav.register') %></a></li>
        <% } %>
      </ul>

      <%# Top-bar right side for mobile: cart + notification bell + dark mode %>
      <div class="top-bar-actions">
        <% if (currentUser) { %>
          <% if (currentUser.role === 'customer') { %>
            <a href="/customer/cart" class="top-bar-cart" aria-label="سلة المشتريات">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6"/></svg>
            </a>
          <% } %>
          <a href="/notifications" class="top-bar-notif" aria-label="الإشعارات">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            <span class="notif-badge" id="notifBadge"<%= (unreadNotificationCount > 0) ? '' : ' style="display:none"' %>><%= unreadNotificationCount || '' %></span>
          </a>
        <% } %>
        <button class="dark-mode-btn" id="darkModeBtn" onclick="toggleDarkMode()" aria-label="تبديل الوضع الليلي">
          <span class="dark-mode-icon dark-mode-icon--moon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          </span>
          <span class="dark-mode-icon dark-mode-icon--sun">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </span>
        </button>
      </div>
    </nav>
  </header>

  <%# ============================================================
      BOTTOM NAVIGATION — role-based, mobile only
      ============================================================ %>

  <% if (currentUser && currentUser.role === 'customer') { %>
  <nav class="bottom-nav" role="navigation" aria-label="التنقل الرئيسي">
    <a href="/" class="bottom-nav-item <%= typeof currentPath !== 'undefined' && currentPath === '/' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      الرئيسية
    </a>
    <a href="/customer/messages" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      الشات
      <span class="bottom-nav-badge" id="msgBadgeCust"<%= (unreadMessageCount > 0) ? '' : ' style="display:none"' %>><%= unreadMessageCount || '' %></span>
    </a>
    <a href="/products" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      المنتجات
    </a>
    <a href="/customer/dashboard" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      حسابي
    </a>
    <button class="bottom-nav-item" onclick="openSideMenu()" aria-label="القائمة">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      المزيد
    </button>
  </nav>

  <% } else if (currentUser && currentUser.role === 'vendor') { %>
  <nav class="bottom-nav" role="navigation" aria-label="التنقل الرئيسي">
    <a href="/" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      الرئيسية
    </a>
    <a href="/vendor/messages" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      الشات
      <span class="bottom-nav-badge" id="msgBadgeVend"<%= (unreadMessageCount > 0) ? '' : ' style="display:none"' %>><%= unreadMessageCount || '' %></span>
    </a>
    <a href="/vendor/products/new" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
      ضيف منتج
    </a>
    <a href="/vendor/store/edit" class="bottom-nav-item">
      <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
