  <%# ============================================================
      SIDE MENU DRAWER — role-based content
      ============================================================ %>
  <div class="side-menu-overlay" id="sideMenu">
    <div class="side-menu-backdrop" onclick="closeSideMenu()"></div>
    <div class="side-menu-drawer" role="dialog" aria-label="القائمة الجانبية">
      <div class="side-menu-header">
        <span class="brand-name"><%= t('app.name') %></span>
        <button class="side-menu-close" onclick="closeSideMenu()" aria-label="إغلاق">&#x2715;</button>
      </div>

      <% if (currentUser) { %>
      <div class="side-menu-user">
        <p class="user-name"><%= currentUser.fullName %></p>
        <p class="user-role">
          <% if (currentUser.role === 'admin') { %>مدير النظام
          <% } else if (currentUser.role === 'vendor') { %>بائع
          <% } else { %>عميل<% } %>
        </p>
      </div>
      <% } %>

      <div class="side-menu-links">

        <% if (currentUser && currentUser.role === 'customer') { %>
          <a href="/customer/cart" class="side-menu-link">
