  <% if (currentUser) { %>
  <script>
  (function() {
    function setBadge(id, count) {
      var el = document.getElementById(id);
      if (!el) return;
      if (count > 0) { el.textContent = count; el.style.display = ''; }
      else { el.style.display = 'none'; }
    }
    function poll() {
      fetch('/notifications/api/badge-counts', { credentials: 'same-origin' })
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(d) {
          if (!d) return;
          setBadge('notifBadge', d.unreadNotifications);
          setBadge('msgBadgeCust', d.unreadMessages);
          setBadge('msgBadgeVend', d.unreadMessages);
          setBadge('msgBadgeSide', d.unreadMessages);
        })
        .catch(function() {});
    }
    setInterval(poll, 8000);
  })();
  </script>
  <% } %>

