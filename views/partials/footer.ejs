  <script>
    (function () {
      var token = "<%= csrfToken %>";
      var forms = document.querySelectorAll('form');
      forms.forEach(function (form) {
        var method = (form.getAttribute('method') || 'GET').toUpperCase();
        if (method === 'POST') {
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = '_csrf';
          input.value = token;
          form.appendChild(input);
        }
      });
    })();

    function toggleDarkMode() {
      var html = document.documentElement;
      var isDark = html.getAttribute('data-theme') === 'dark';
      if (isDark) {
        html.removeAttribute('data-theme');
        localStorage.setItem('mghagha-theme', 'light');
      } else {
        html.setAttribute('data-theme', 'dark');
        localStorage.setItem('mghagha-theme', 'dark');
      }
    }

    function openSideMenu() {
      var menu = document.getElementById('sideMenu');
      if (menu) {
        menu.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeSideMenu() {
      var menu = document.getElementById('sideMenu');
      if (menu) {
        menu.classList.remove('open');
        document.body.style.overflow = '';
      }
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeSideMenu();
    });

    (function() {
      var path = window.location.pathname;
      var items = document.querySelectorAll('.bottom-nav-item');
      items.forEach(function(item) {
        if (item.tagName === 'A') {
          var href = item.getAttribute('href');
          if (href && href !== '#' && (path === href || (href !== '/' && path.startsWith(href)))) {
            item.classList.add('active');
          }
        }
      });
    })();

    (function () {
      function initImageUpload(input) {
        var wrap = input.closest('.pf-file-wrap') || input.parentElement;
        var label = wrap.querySelector('.pf-file-label') || wrap.querySelector('label');
        var spinner = document.createElement('span');
        spinner.className = 'img-upload-spinner';
        spinner.innerHTML = '<svg class="spin-svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" opacity=".25"/><path d="M12 2a10 10 0 010 20" stroke-dasharray="30" stroke-dashoffset="30" opacity=".75"/></svg>';
        spinner.style.cssText = 'display:none;margin-right:8px;vertical-align:middle;';
        var preview = document.createElement('div');
        preview.className = 'img-upload-preview';
        preview.style.cssText = 'display:none;margin-top:10px;gap:8px;flex-wrap:wrap;';
        var successMsg = document.createElement('p');
        successMsg.className = 'img-upload-success';
        successMsg.style.cssText = 'display:none;color:#2e7d32;font-size:0.85rem;margin:6px 0 0;font-weight:600;';
        successMsg.textContent = '✅ الصورة اتحددت بنجاح';
        if (label) label.appendChild(spinner);
        wrap.appendChild(preview);
        wrap.appendChild(successMsg);
        input.addEventListener('change', function () {
          var files = Array.from(this.files);
          if (!files.length) return;
          spinner.style.display = 'inline-block';
          preview.style.display = 'none';
          successMsg.style.display = 'none';
          preview.innerHTML = '';
          var loaded = 0;
          files.forEach(function (file) {
            if (!file.type.startsWith('image/')) { loaded++; return; }
            var reader = new FileReader();
            reader.onload = function (e) {
              var img = document.createElement('img');
              img.src = e.target.result;
              img.style.cssText = 'width:72px;height:72px;object-fit:cover;border-radius:8px;border:2px solid #2e7d32;display:inline-block;';
              preview.appendChild(img);
              loaded++;
              if (loaded === files.length) {
                spinner.style.display = 'none';
                preview.style.display = 'flex';
                successMsg.style.display = 'block';
                successMsg.textContent = files.length > 1
                  ? '✅ ' + files.length + ' صور اتحددوا بنجاح'
                  : '✅ الصورة اتحددت بنجاح';
              }
            };
            reader.onerror = function () {
              loaded++;
              if (loaded === files.length) spinner.style.display = 'none';
            };
            reader.readAsDataURL(file);
          });
        });
      }
      function attachAll() {
        document.querySelectorAll('input[type="file"]').forEach(function (input) {
          if (!input.dataset.uploadInit) {
            input.dataset.uploadInit = '1';
            initImageUpload(input);
          }
        });
      }
      attachAll();
      var obs = new MutationObserver(attachAll);
      obs.observe(document.body, { childList: true, subtree: true });
    })();

    var _spinStyle = document.createElement('style');
    _spinStyle.textContent = '@keyframes spin{to{transform:rotate(360deg)}}.spin-svg{animation:spin .8s linear infinite;}.img-upload-spinner{display:inline-flex;align-items:center;}';
    document.head.appendChild(_spinStyle);

    (function() {
      function buildCSD(select) {
        if (select.dataset.csdInit) return;
        select.dataset.csdInit = '1';
        select.style.cssText = 'position:absolute;opacity:0;pointer-events:none;width:0;height:0;';

        var wrap = document.createElement('div');
        wrap.className = 'csd-wrap';
        select.parentNode.insertBefore(wrap, select);
        wrap.appendChild(select);

        var trigger = document.createElement('button');
        trigger.type = 'button';
        trigger.className = 'csd-trigger';
        trigger.setAttribute('aria-haspopup', 'listbox');
        trigger.setAttribute('aria-expanded', 'false');
        if (select.required) trigger.setAttribute('aria-required', 'true');

        var label = document.createElement('span');
        label.className = 'csd-label';

        var svgNS = 'http://www.w3.org/2000/svg';
        var arrow = document.createElementNS(svgNS, 'svg');
        arrow.setAttribute('viewBox', '0 0 24 24');
        arrow.setAttribute('fill', 'none');
        arrow.setAttribute('stroke', 'currentColor');
        arrow.setAttribute('stroke-width', '2.5');
        arrow.setAttribute('stroke-linecap', 'round');
        arrow.setAttribute('stroke-linejoin', 'round');
        arrow.classList.add('csd-arrow');
        var pl = document.createElementNS(svgNS, 'polyline');
        pl.setAttribute('points', '6 9 12 15 18 9');
        arrow.appendChild(pl);

        trigger.appendChild(label);
        trigger.appendChild(arrow);

        var panel = document.createElement('div');
        panel.className = 'csd-panel';
        panel.setAttribute('role', 'listbox');

        wrap.appendChild(trigger);
        wrap.appendChild(panel);

        function buildOptions() {
          panel.innerHTML = '';
          Array.from(select.options).forEach(function(opt) {
            var item = document.createElement('div');
            item.className = 'csd-option' + (opt.value === '' ? ' csd-placeholder' : '');
            item.setAttribute('role', 'option');
            item.textContent = opt.text;
            item.dataset.value = opt.value;
            if (select.value === opt.value) item.classList.add('csd-active');
            item.addEventListener('mousedown', function(e) {
              e.preventDefault();
              pick(opt.value, opt.text);
              close();
            });
            panel.appendChild(item);
          });
        }

        function pick(val, text) {
          select.value = val;
          select.dispatchEvent(new Event('change', { bubbles: true }));
          refreshLabel();
        }

        function refreshLabel() {
          var sel = select.options[select.selectedIndex];
          if (sel && sel.value) {
            label.textContent = sel.text;
            trigger.classList.add('has-value');
          } else {
            label.textContent = select.options[0] ? select.options[0].text : '';
            trigger.classList.remove('has-value');
          }
          Array.from(panel.children).forEach(function(item) {
            item.classList.toggle('csd-active', item.dataset.value === select.value);
          });
        }

        function open() {
          buildOptions();
          panel.classList.add('open');
          trigger.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }

        function close() {
          panel.classList.remove('open');
          trigger.classList.remove('open');
          trigger.setAttribute('aria-expanded', 'false');
        }

        trigger.addEventListener('click', function(e) {
          e.stopPropagation();
          panel.classList.contains('open') ? close() : open();
        });

        trigger.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); panel.classList.contains('open') ? close() : open(); }
          else if (e.key === 'Escape') close();
        });

        document.addEventListener('click', function(e) {
          if (!wrap.contains(e.target)) close();
        });

        wrap._csdRefresh = function() { buildOptions(); refreshLabel(); };
        select._csdWrap = wrap;

        refreshLabel();
      }

      window.csdRefresh = function(sel) {
        if (!sel) return;
        if (sel._csdWrap) sel._csdWrap._csdRefresh();
        else buildCSD(sel);
      };

      function initAll() {
        document.querySelectorAll('select.auth-input, select.pf-custom-select, select.pf-input, select[data-csd]').forEach(function(s) {
          if (!s.dataset.csdInit) buildCSD(s);
        });
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initAll);
      else initAll();

      var csdObs = new MutationObserver(function(muts) {
        muts.forEach(function(m) {
          m.addedNodes.forEach(function(n) {
            if (n.nodeType !== 1) return;
            var sels = [];
            if (n.matches && (n.matches('select.auth-input,select.pf-custom-select,select.pf-input,select[data-csd]'))) sels.push(n);
            if (n.querySelectorAll) n.querySelectorAll('select.auth-input,select.pf-custom-select,select.pf-input,select[data-csd]').forEach(function(s){ sels.push(s); });
            sels.forEach(function(s){ if (!s.dataset.csdInit) buildCSD(s); });
          });
        });
      });
      csdObs.observe(document.body, { childList: true, subtree: true });
    })();
  </script>
</body>
</html>
