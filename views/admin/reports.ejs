<%- include('../partials/header', { title: 'بلاغات المنتجات' }) %>
<div class="container">
  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">🚨 بلاغات المنتجات</h1>
      <p style="margin:0;color:var(--color-muted);font-size:.88rem;">البلاغات المنتظرة من المستخدمين</p>
    </div>
    <a href="/admin/dashboard" class="btn btn-secondary">← لوحة الإدارة</a>
  </div>

  <% if (locals.flash && flash.type) { %>
    <div class="alert alert-<%= flash.type %>" style="margin-bottom:16px;padding:12px 16px;border-radius:8px;background:<%= flash.type==='success'?'#e8f5e9':'#fdecea' %>;color:<%= flash.type==='success'?'#2e7d32':'#c62828' %>;font-weight:600;">
      <%= flash.text %>
    </div>
  <% } %>

  <% if (reports.length === 0) { %>
    <div class="empty-state" style="padding:48px 0;text-align:center;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--color-muted);margin-bottom:12px;"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <p style="color:var(--color-muted);font-size:1rem;">لا توجد بلاغات معلقة حالياً 🎉</p>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:16px;">
      <% reports.forEach(function(report) { %>
        <div style="background:var(--color-card);border:1px solid var(--color-border);border-radius:12px;padding:16px 20px;display:flex;flex-direction:column;gap:12px;">

          <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap;">
            <div style="flex:1;min-width:200px;">
              <p style="margin:0 0 4px;font-weight:700;font-size:1rem;">
                <% if (report.product_name) { %>
                  📦 <%= report.product_name %>
                  <% if (report.product_status === 'inactive') { %>
                    <span style="background:#fee2e2;color:#b91c1c;border-radius:20px;padding:2px 10px;font-size:.75rem;margin-right:6px;">معطّل</span>
                  <% } %>
                <% } else { %>
                  <span style="color:var(--color-muted);">[منتج محذوف]</span>
                <% } %>
              </p>
              <p style="margin:0;color:var(--color-muted);font-size:.85rem;">
                🏪 <%= report.store_name || '—' %>
              </p>
            </div>
            <div style="text-align:left;">
              <p style="margin:0;font-size:.82rem;color:var(--color-muted);direction:ltr;"><%= new Date(report.created_at).toLocaleDateString('ar-EG') %></p>
            </div>
          </div>

          <div style="background:var(--color-bg);border-radius:8px;padding:10px 14px;">
            <p style="margin:0;font-size:.88rem;">
              <strong>سبب البلاغ:</strong>
              <%
                var reasonLabels = {
                  fraud: 'إعلان احتيالي أو مضلل',
                  prohibited: 'منتج ممنوع أو غير قانوني',
                  inappropriate: 'محتوى غير لائق',
                  spam: 'إعلان مكرر أو سبام',
                  wrong_price: 'سعر مزيف أو مضلل'
                };
              %>
              <%= reasonLabels[report.reason] || report.reason %>
            </p>
            <p style="margin:4px 0 0;font-size:.82rem;color:var(--color-muted);">
              بلّغ بواسطة: <%= report.reporter_name || 'مجهول' %>
            </p>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px;">
            <% if (report.product_name && report.store_slug) { %>
              <a href="/stores/<%= report.store_slug %>/products/<%= report.product_name %>"
                 target="_blank"
                 style="display:inline-flex;align-items:center;gap:4px;padding:6px 14px;border-radius:8px;background:var(--color-bg);border:1px solid var(--color-border);font-size:.85rem;color:var(--color-text);text-decoration:none;">
                👁 عرض المنتج
              </a>
            <% } %>

            <% if (report.product_name && report.product_status !== 'inactive') { %>
              <form action="/admin/reports/<%= report.id %>/disable-product" method="POST" class="inline-form">
                <button type="submit" class="btn btn-small" style="background:#fff3cd;color:#856404;border:1px solid #ffc107;"
                  onclick="return confirm('هل تريد تعطيل هذا المنتج؟')">
                  ⛔ تعطيل المنتج
                </button>
              </form>
            <% } %>

            <% if (report.product_name) { %>
              <form action="/admin/reports/<%= report.id %>/delete-product" method="POST" class="inline-form">
                <button type="submit" class="btn btn-small btn-danger"
                  onclick="return confirm('هل تريد حذف هذا المنتج نهائياً؟ لا يمكن التراجع عن هذا الإجراء.')">
                  🗑 حذف المنتج نهائياً
                </button>
              </form>
            <% } %>

            <form action="/admin/reports/<%= report.id %>/dismiss" method="POST" class="inline-form">
              <button type="submit" class="btn btn-small btn-secondary">
                ✓ تجاهل البلاغ
              </button>
            </form>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
