<%- include('../partials/header', { title: 'إشراف على إعلانات البيع' }) %>
<div class="container">
  <div class="page-header-row" style="margin-bottom:22px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.5rem;">📋 إشراف على إعلانات البيع</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">مراجعة وإدارة إعلانات "بيع حاجة مستعملة"</p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline" style="align-self:flex-start;">← لوحة التحكم</a>
  </div>

  <%- include('../partials/flash') %>

  <!-- Filters -->
  <form method="GET" action="/admin/classifieds-moderation" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;align-items:flex-end;">
    <div style="flex:1;min-width:180px;">
      <label class="pf-label" style="font-size:0.82rem;">بحث</label>
      <input type="text" name="search" class="pf-input" value="<%= currentSearch %>" placeholder="اسم الإعلان أو البائع...">
    </div>
    <div>
      <label class="pf-label" style="font-size:0.82rem;">الحالة</label>
      <select name="status" class="pf-input">
        <option value="">الكل</option>
        <option value="active" <%= currentStatus === 'active' ? 'selected' : '' %>>نشط</option>
        <option value="hidden" <%= currentStatus === 'hidden' ? 'selected' : '' %>>مخفي</option>
        <option value="removed" <%= currentStatus === 'removed' ? 'selected' : '' %>>محذوف</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary" style="align-self:flex-end;">🔍 بحث</button>
    <a href="/admin/classifieds-moderation" class="btn btn-outline" style="align-self:flex-end;">مسح</a>
  </form>

  <div class="pf-section">
    <div class="pf-section-title">
      <span>📦</span>
      <span>الإعلانات (<%= listings.length %>)</span>
    </div>

    <% if (listings.length === 0) { %>
      <p style="text-align:center;padding:40px 0;color:var(--color-muted);">لا توجد إعلانات تطابق البحث.</p>
    <% } else { %>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
        <thead>
          <tr style="background:var(--color-bg-alt);">
            <th style="padding:10px 12px;text-align:right;">#</th>
            <th style="padding:10px 12px;text-align:right;">الإعلان</th>
            <th style="padding:10px 12px;text-align:right;">البائع</th>
            <th style="padding:10px 12px;text-align:center;">السعر</th>
            <th style="padding:10px 12px;text-align:center;">الحالة</th>
            <th style="padding:10px 12px;text-align:right;">التاريخ</th>
            <th style="padding:10px 12px;text-align:center;">إجراءات</th>
          </tr>
        </thead>
        <tbody>
          <% listings.forEach(function(l) { %>
          <tr style="border-bottom:1px solid var(--color-border);<%= l.moderation_status === 'removed' ? 'opacity:0.6;' : '' %>">
            <td style="padding:10px 12px;color:var(--color-muted);"><%= l.id %></td>
            <td style="padding:10px 12px;">
              <a href="/classifieds/<%= l.slug %>" target="_blank" style="font-weight:600;color:var(--color-primary);text-decoration:none;">
                <%= l.name %>
              </a>
              <% if (l.category_name) { %>
                <br><small style="color:var(--color-muted);"><%= l.category_name %></small>
              <% } %>
            </td>
            <td style="padding:10px 12px;">
              <%= l.seller_name || '—' %>
              <% if (l.seller_phone) { %><br><small style="color:var(--color-muted);"><%= l.seller_phone %></small><% } %>
            </td>
            <td style="padding:10px 12px;text-align:center;font-weight:600;">
              <%= l.price > 0 ? l.price.toLocaleString('ar-EG') + ' ج.م' : 'تواصل للسعر' %>
            </td>
            <td style="padding:10px 12px;text-align:center;">
              <% if (l.moderation_status === 'active') { %>
                <span style="background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:20px;font-size:0.8rem;">نشط</span>
              <% } else if (l.moderation_status === 'hidden') { %>
                <span style="background:#fef3c7;color:#92400e;padding:3px 10px;border-radius:20px;font-size:0.8rem;">مخفي</span>
              <% } else { %>
                <span style="background:#fee2e2;color:#991b1b;padding:3px 10px;border-radius:20px;font-size:0.8rem;">محذوف</span>
              <% } %>
            </td>
            <td style="padding:10px 12px;white-space:nowrap;color:var(--color-muted);font-size:0.8rem;">
              <%= new Date(l.created_at).toLocaleDateString('ar-EG') %>
            </td>
            <td style="padding:10px 12px;text-align:center;">
              <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;">
                <% if (l.moderation_status === 'active') { %>
                  <form action="/admin/classifieds-moderation/<%= l.id %>/hide" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm" style="background:#fef3c7;color:#92400e;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;">إخفاء</button>
                  </form>
                  <form action="/admin/classifieds-moderation/<%= l.id %>/remove" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm" style="background:#fee2e2;color:#991b1b;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;">إزالة</button>
                  </form>
                <% } else if (l.moderation_status === 'hidden') { %>
                  <form action="/admin/classifieds-moderation/<%= l.id %>/restore" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm" style="background:#d1fae5;color:#065f46;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;">استعادة</button>
                  </form>
                  <form action="/admin/classifieds-moderation/<%= l.id %>/remove" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm" style="background:#fee2e2;color:#991b1b;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;">إزالة</button>
                  </form>
                <% } else { %>
                  <form action="/admin/classifieds-moderation/<%= l.id %>/restore" method="POST" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm" style="background:#d1fae5;color:#065f46;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;">استعادة</button>
                  </form>
                <% } %>
                <form action="/admin/classifieds-moderation/<%= l.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من الحذف النهائي؟ لا يمكن التراجع عن هذا الإجراء.')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm" style="background:#111;color:#fff;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;">حذف نهائي</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
