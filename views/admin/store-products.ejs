<%- include('../partials/header', { title: 'منتجات المتجر' }) %>
<div class="container">
  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">منتجات <%= store.store_name %></h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">إدارة وتعديل منتجات هذا المتجر</p>
    </div>
    <a href="/admin/stores" class="btn btn-secondary btn-small">← رجوع إلى المتاجر</a>
  </div>

  <% if (products.length === 0) { %>
    <div class="info-card" style="text-align:center;padding:40px 20px;">
      <p style="font-size:2rem;margin-bottom:8px;">📦</p>
      <p style="color:var(--color-muted);">لا توجد منتجات لهذا المتجر.</p>
    </div>
  <% } else { %>
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>المنتج</th>
            <th>السعر</th>
            <th>المخزون</th>
            <th>الحالة</th>
            <th style="text-align:center;">الإجراءات</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(function(p) { %>
            <tr>
              <td style="font-weight:600;max-width:200px;"><%= p.name %></td>
              <td><%= p.price.toFixed(2) %> ج.م</td>
              <td>
                <% if (p.quantity === 0) { %>
                  <span style="color:var(--color-danger);font-weight:700;">0 — خلصان</span>
                <% } else { %>
                  <span style="color:var(--color-success);font-weight:600;"><%= p.quantity %></span>
                <% } %>
              </td>
              <td>
                <span class="badge badge-<%= p.status === 'active' ? 'success' : 'muted' %>">
                  <%= p.status === 'active' ? '✓ نشط' : '✗ متوقف' %>
                </span>
              </td>
              <td>
                <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;">
                  <form action="/admin/stores/<%= store.id %>/products/<%= p.id %>/toggle-status" method="POST" class="inline-form">
                    <button type="submit" class="btn btn-small btn-secondary">
                      <%= p.status === 'active' ? 'إيقاف' : 'تفعيل' %>
                    </button>
                  </form>
                  <form action="/admin/stores/<%= store.id %>/products/<%= p.id %>/delete" method="POST" class="inline-form"
                    onsubmit="return confirm('هل أنت متأكد من حذف المنتج نهائياً؟ لا يمكن التراجع عن هذا الإجراء.')">
                    <button type="submit" class="btn btn-small btn-danger">🗑 حذف المنتج</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
