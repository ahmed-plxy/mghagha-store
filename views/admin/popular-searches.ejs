<%- include('../partials/header', { title: 'الكلمات الشائعة في البحث' }) %>
<div class="container">
  <div class="page-header-row" style="margin-bottom:20px;">
    <div>
      <h1 style="margin:0 0 4px;font-size:1.4rem;">🔎 الكلمات الشائعة في البحث</h1>
      <p style="margin:0;color:var(--color-muted);font-size:0.88rem;">الكلمات اللي تظهر كاقتراحات سريعة في الصفحة الرئيسية وصفحة المنتجات — اضغط عليها العميل فيبحث بيها على طول</p>
    </div>
  </div>

  <!-- Add Form -->
  <div class="pf-section" style="margin-bottom:24px;">
    <div class="pf-section-title"><span>➕</span><span>إضافة كلمة جديدة</span></div>
    <form action="/admin/popular-searches" method="POST">
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:12px;">
        <div class="form-group" style="margin:0;">
          <label>كلمة البحث <span style="color:var(--color-danger);">*</span></label>
          <input type="text" name="term" placeholder="مثال: موبايل مستعمل في مغاغة" required class="form-control">
        </div>
        <div class="form-group" style="margin:0;">
          <label>ترتيب العرض</label>
          <input type="number" name="sortOrder" value="0" min="0" class="form-control">
          <p class="form-hint">الرقم الأصغر يظهر أولاً</p>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">إضافة الكلمة</button>
    </form>
  </div>

  <!-- Existing Searches -->
  <div class="pf-section">
    <div class="pf-section-title"><span>📋</span><span>الكلمات الحالية (<%= searches.length %>)</span></div>
    <% if (searches.length === 0) { %>
      <div style="text-align:center;padding:40px 20px;color:var(--color-muted);">
        <p style="font-size:2.5rem;margin-bottom:8px;">🔎</p>
        <p>لا توجد كلمات بعد. أضف أول كلمة من الأعلى.</p>
      </div>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <% searches.forEach(function(s) { %>
          <!-- Main row -->
          <div class="card" style="padding:0;border:2px solid <%= s.is_active ? 'var(--color-primary)' : 'var(--color-border)' %>;opacity:<%= s.is_active ? 1 : 0.6 %>;">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;padding:12px 16px;">
              <div style="display:flex;align-items:center;gap:10px;">
                <span class="badge <%= s.is_active ? 'badge-success' : 'badge-muted' %>"><%= s.is_active ? '✓ نشط' : '✗ متوقف' %></span>
                <span style="font-weight:700;"><%= s.term %></span>
                <span style="font-size:0.8rem;color:var(--color-muted);">ترتيب: <%= s.sort_order %></span>
              </div>
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <button type="button" class="btn btn-small btn-secondary"
                  onclick="toggleEditForm(<%= s.id %>)">✏️ تعديل</button>
                <form action="/admin/popular-searches/<%= s.id %>/toggle" method="POST" class="inline-form">
                  <button type="submit" class="btn btn-small btn-secondary"><%= s.is_active ? 'إيقاف' : 'تفعيل' %></button>
                </form>
                <form action="/admin/popular-searches/<%= s.id %>/delete" method="POST" class="inline-form"
                  onsubmit="return confirm('تأكيد حذف هذه الكلمة؟')">
                  <button type="submit" class="btn btn-small btn-danger">🗑 حذف</button>
                </form>
              </div>
            </div>
            <!-- Inline Edit Form (hidden by default) -->
            <div id="edit-form-<%= s.id %>" style="display:none;border-top:1px solid var(--color-border);padding:14px 16px;background:var(--color-bg-soft,#f8f9fa);">
              <form action="/admin/popular-searches/<%= s.id %>/update" method="POST">
                <div style="display:grid;grid-template-columns:2fr 1fr auto;gap:10px;align-items:end;">
                  <div class="form-group" style="margin:0;">
                    <label style="font-size:0.85rem;">كلمة البحث</label>
                    <input type="text" name="term" value="<%= s.term %>" required class="form-control" style="font-size:0.9rem;">
                  </div>
                  <div class="form-group" style="margin:0;">
                    <label style="font-size:0.85rem;">الترتيب</label>
                    <input type="number" name="sortOrder" value="<%= s.sort_order %>" min="0" class="form-control" style="font-size:0.9rem;">
                  </div>
                  <div style="display:flex;gap:6px;">
                    <button type="submit" class="btn btn-primary btn-small">💾 حفظ</button>
                    <button type="button" class="btn btn-small btn-secondary" onclick="toggleEditForm(<%= s.id %>)">إلغاء</button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<script>
function toggleEditForm(id) {
  var el = document.getElementById('edit-form-' + id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>

<%- include('../partials/footer') %>
